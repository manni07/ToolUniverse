[
  {
    "name": "PharmGKB_search_drugs",
    "description": "Search for drugs in PharmGKB by name or PharmGKB ID. Returns drug name, ID, and basic metadata.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Drug name or PharmGKB Chemical ID (e.g., 'warfarin', 'PA452637'). Aliases: drug_name, name, drug."
        },
        "drug_name": {
          "type": "string",
          "description": "Alias for query. Drug name to search (e.g., 'warfarin', 'metformin')."
        },
        "name": {
          "type": "string",
          "description": "Alias for query. Drug name to search."
        },
        "drug": {
          "type": "string",
          "description": "Alias for query. Drug name to search."
        }
      },
      "required": []
    },
    "fields": {
      "operation": "search_drugs"
    },
    "type": "PharmGKBTool",
    "test_examples": [
      {
        "query": "warfarin"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "objCls": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "inChi": {
                "type": "string"
              },
              "smiles": {
                "type": "string"
              },
              "types": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "PharmGKB_get_drug_details",
    "description": "Get detailed information for a drug using its PharmGKB Chemical ID. Returns structural info, cross-references, and related genes.",
    "parameter": {
      "type": "object",
      "properties": {
        "drug_id": {
          "type": "string",
          "description": "PharmGKB Chemical ID (e.g., 'PA452637')."
        }
      },
      "required": [
        "drug_id"
      ]
    },
    "fields": {
      "operation": "drug_details"
    },
    "type": "PharmGKBTool",
    "test_examples": [
      {
        "drug_id": "PA452637"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "objCls": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "pediatric": {
          "type": "boolean"
        },
        "types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  {
    "name": "PharmGKB_search_genes",
    "description": "Search for genes in PharmGKB by name, symbol, or ID. Returns PharmGKB Gene ID and basic gene metadata.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Gene name, symbol, or PharmGKB Accession ID (e.g., 'CYP2D6', 'PA128')."
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "operation": "search_genes"
    },
    "type": "PharmGKBTool",
    "test_examples": [
      {
        "query": "CYP2D6"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "objCls": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "chr": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  },
  {
    "name": "PharmGKB_get_gene_details",
