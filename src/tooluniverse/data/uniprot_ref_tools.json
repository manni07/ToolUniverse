                  "type": "string"
                },
                "definition": {
                  "type": "string"
                },
                "alternative_names": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cross_references": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "database": {
                        "type": "string"
                      },
                      "id": {
                        "type": "string"
                      },
                      "properties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "reviewed_protein_count": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "unreviewed_protein_count": {
                  "type": [
                    "integer",
                    "number"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
