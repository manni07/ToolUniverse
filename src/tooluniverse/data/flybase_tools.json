[
  {
    "name": "FlyBase_get_gene",
    "description": "Get detailed Drosophila melanogaster (fruit fly) gene information from FlyBase via the Alliance of Genome Resources. Returns gene symbol, name, synopsis, genomic location, synonyms, and cross-references. FlyBase is the primary database for Drosophila genetics. Example: 'FB:FBgn0003996' returns the white (w) gene with its function as an ABCG2-class transporter.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "FlyBase gene ID with 'FB:' prefix. Examples: 'FB:FBgn0003996' (white/w), 'FB:FBgn0000490' (decapentaplegic/dpp), 'FB:FBgn0004647' (Notch/N), 'FB:FBgn0000546' (eyeless/ey), 'FB:FBgn0003731' (hedgehog/hh)."
        }
      },
      "required": [
        "gene_id"
      ]
    },
    "fields": {
      "endpoint_type": "gene_detail"
    },
    "type": "AllianceGenomeTool",
    "test_examples": [
      {
        "gene_id": "FB:FBgn0003996"
      },
      {
        "gene_id": "FB:FBgn0000490"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "id": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "symbol": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "name": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "species": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "short_name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "taxon_id": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "data_provider": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                },
                "gene_synopsis": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "automated_gene_synopsis": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "synonyms": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "so_term": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "genomic_location": {
                  "type": "object",
                  "properties": {
                    "chromosome": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "start": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "end": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "assembly": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "strand": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                },
                "cross_references": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "url": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                }
              }
