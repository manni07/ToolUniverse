                  "title": {
                    "type": "string"
                  },
                  "abstract": {
                    "type": "string"
                  },
                  "authors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "journal": {
                    "type": "string"
                  },
                  "year": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "source_db": {
                    "type": "string"
                  },
                  "article_id": {
                    "type": "string"
                  },
                  "pmid": {
                    "type": "string"
                  },
                  "pmcid": {
                    "type": [
                      "null",
                      "string"
                    ]
                  },
                  "doi_url": {
                    "type": "string"
                  },
                  "fulltext_xml_url": {
                    "type": [
                      "null",
                      "string"
                    ]
                  },
                  "citations": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "open_access": {
                    "type": "boolean"
                  },
                  "keywords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "source": {
                    "type": "string"
                  },
                  "data_quality": {
                    "type": "object",
                    "properties": {
                      "has_abstract": {
                        "type": "boolean"
                      },
                      "has_authors": {
                        "type": "boolean"
                      },
                      "has_journal": {
                        "type": "boolean"
                      },
                      "has_year": {
                        "type": "boolean"
                      },
                      "has_doi": {
                        "type": "boolean"
                      },
                      "has_citations": {
                        "type": "boolean"
                      },
                      "has_keywords": {
                        "type": "boolean"
                      },
                      "has_url": {
