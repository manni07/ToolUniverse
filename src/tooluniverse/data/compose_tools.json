[
  {
    "type": "ComposeTool",
    "name": "DrugSafetyAnalyzer",
    "description": "Comprehensive drug safety analysis combining adverse event data, literature review, and molecular information",
    "parameter": {
      "type": "object",
      "properties": {
        "drug_name": {
          "type": "string",
          "description": "Name of the drug to analyze"
        },
        "patient_sex": {
          "type": "string",
          "enum": [
            "Male",
            "Female"
          ],
          "description": "Filter by patient sex (optional)"
        },
        "serious_events_only": {
          "type": "boolean",
          "description": "Focus only on serious adverse events",
          "default": false
        }
      },
      "required": [
        "drug_name",
        "patient_sex",
        "serious_events_only"
      ]
    },
    "auto_load_dependencies": true,
    "fail_on_missing_tools": false,
    "required_tools": [
      "PubChem_get_CID_by_compound_name",
      "PubChem_get_compound_properties_by_CID",
      "EuropePMC_search_articles"
    ],
    "composition_file": "drug_safety_analyzer.py",
    "composition_function": "compose",
    "test_examples": [
      {
        "drug_name": "Aspirin",
        "patient_sex": "Female",
        "serious_events_only": true
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "drug_name": {
          "type": "string"
        },
        "analysis_parameters": {
          "type": "object",
          "properties": {
            "patient_sex_filter": {
              "type": "string"
            },
            "serious_events_only": {
              "type": "boolean"
            }
          }
        },
        "adverse_events": {
          "type": "object",
          "properties": {
            "result": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "term": {
                    "type": "string"
                  },
                  "count": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  }
                }
              }
            }
          }
        },
        "molecular_properties": {
          "type": "null"
        },
        "safety_literature": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "data": {
              "type": "array",
              "items": {
