                                            "null"
                                        ]
                                    },
                                    "description": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    },
                                    "tax_id": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    },
                                    "taxname": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    },
                                    "common_name": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    },
                                    "type": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    },
                                    "chromosomes": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "total_results": {
                                    "type": "integer"
                                },
                                "query_gene_id": {
                                    "type": "string"
                                },
