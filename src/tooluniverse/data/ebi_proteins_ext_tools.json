[
  {
    "name": "EBIProteins_get_mutagenesis",
    "description": "Get mutagenesis experiment data for a protein from the EBI Proteins API. Returns experimentally characterized mutations with their functional effects, including gain/loss of function, binding changes, and structural impacts. Data is curated from UniProtKB with literature evidence. Essential for understanding structure-function relationships. Example: P04637 (TP53) returns 651 mutagenesis annotations showing effects of each mutation on p53 function.",
    "parameter": {
      "type": "object",
      "properties": {
        "accession": {
          "type": "string",
          "description": "UniProt accession. Examples: 'P04637' (TP53/p53), 'P38398' (BRCA1), 'P00533' (EGFR), 'P01308' (Insulin)."
        }
      },
      "required": [
        "accession"
      ]
    },
    "fields": {
      "endpoint": "mutagenesis"
    },
    "type": "EBIProteinsExtTool",
    "test_examples": [
      {
        "accession": "P04637"
      },
      {
        "accession": "P00533"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "accession": {
                  "type": "string"
                },
                "entry_name": {
                  "type": "string"
                },
                "gene_name": {
                  "type": "null"
                },
                "features": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "position_start": {
                        "type": "string"
                      },
                      "position_end": {
                        "type": "string"
                      },
                      "original_sequence": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "evidences": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "string"
                            },
                            "source_name": {
                              "type": "string"
                            },
                            "source_id": {
                              "type": "string"
                            },
