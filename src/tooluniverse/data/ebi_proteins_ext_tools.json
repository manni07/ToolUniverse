                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "category_queried": {
                  "type": "string"
                },
                "features": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "category": {
                        "type": "string"
                      },
                      "position_start": {
                        "type": "string"
                      },
                      "position_end": {
                        "type": "string"
                      },
                      "description": {
                        "type": [
                          "null",
                          "string"
                        ]
                      },
                      "evidences": {
                        "type": [
                          "array",
