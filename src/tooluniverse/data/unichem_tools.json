                        ]
                      },
                      "last_updated": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
