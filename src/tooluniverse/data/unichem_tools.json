                "source_count": {
                  "type": "integer"
                },
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "source_id": {
                        "type": "integer"
                      },
                      "name": {
                        "type": "string"
                      },
                      "long_name": {
                        "type": "string"
                      },
                      "description": {
