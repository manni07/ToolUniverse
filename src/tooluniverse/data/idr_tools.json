  {
    "name": "IDR_list_dataset_images",
    "description": "List the individual images contained in a specific IDR (Image Data Resource) dataset, drilling down from the dataset level to the per-image level. Each IDR dataset (a collection of related microscopy images, e.g. one experimental plate or condition) contains many images; this tool returns their image IDs and names. Use the returned image IDs to fetch per-image map annotations (IDR_get_image_map_annotations), thumbnails, or pixel data. Obtain dataset IDs first from IDR_get_study_datasets. Supports limit/offset pagination; meta.totalCount gives the total number of images in the dataset.",
    "parameter": {
      "type": "object",
      "properties": {
        "dataset_id": {
          "type": "integer",
          "description": "IDR dataset ID (e.g. 51). Obtain from IDR_get_study_datasets."
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of images to return (default 25, max 1000)."
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Offset for pagination."
        }
      },
      "required": [
        "dataset_id"
      ]
    },
    "fields": {
      "endpoint": "https://idr.openmicroscopy.org/api/v0/m/datasets/{dataset_id}/images/"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "dataset_id": 51,
        "limit": 5
      },
      {
        "dataset_id": 51,
        "limit": 10,
        "offset": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
