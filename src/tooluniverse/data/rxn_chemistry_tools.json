                    "type": "object",
                    "properties": {
                      "smiles": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "confidence": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "count": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      }
                    }
                  }
                },
                "route_count": {
                  "type": "integer"
                },
                "prediction_id": {
                  "type": "string"
                },
                "ai_model": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "status",
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
