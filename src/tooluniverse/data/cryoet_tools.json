  {
    "name": "CryoET_list_depositions",
    "type": "CryoETTool",
    "required_packages": [
      "requests"
    ],
    "description": "Browse depositions from the CZ BioHub CryoET Data Portal. A deposition is the top-level submission unit that bundles a set of datasets, runs, tomograms, and annotations under one author submission, and carries cross-database links (e.g. EMDB entries) in relatedDatabaseEntries. The portal UI is organized by deposition, so this is the natural entry point for browsing what has been submitted. Returns, per deposition: id, title, description, deposition/release/lastModified dates, relatedDatabaseEntries (comma-separated EMDB/other IDs), publications, and a key photo URL. Optionally filter by deposition_id. Example: id 10014 'Dolichospermum flos-aquae ... by Przemek Dutka', relatedDatabaseEntries 'EMD-29922,EMD-29923,EMD-29924,EMD-29925'; id 10019 Bacillus subtilis.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "description": "Operation type",
          "enum": [
            "list_depositions"
          ],
          "default": "list_depositions"
        },
        "deposition_id": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Optional: fetch a single deposition by numeric ID (e.g. 10014)."
        },
        "limit": {
