  {
    "name": "CryoET_list_tiltseries",
    "type": "CryoETTool",
    "required_packages": [
      "requests"
    ],
    "description": "List tilt-series RAW ACQUISITION metadata from the CZ BioHub CryoET Data Portal. A tilt-series is the set of projection images acquired at incremental stage tilts, the raw input later reconstructed into a tomogram. This is distinct from CryoET_list_tomograms (the downstream reconstructions). Returns, per tilt-series: microscope manufacturer/model, acceleration voltage (V), spherical aberration constant, tilt range (tiltMin/tiltMax) and tiltStep (degrees), tilt axis, total electron flux/dose, camera model/manufacturer, acquisition software, binning, pixel spacing, alignment status, and the raw MRC file URL (httpsMrcFile). Optionally filter by run_id. Example: id 8009 (runId 8260) = TFS Krios, 300000 V, tilt -65..65 step 1.0, totalFlux 120.0, camera K2, software UCSFTomo.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "description": "Operation type",
          "enum": [
            "list_tiltseries"
          ],
          "default": "list_tiltseries"
        },
        "run_id": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Optional: filter to tilt-series of a single run (e.g. 8260). Obtain from CryoET_list_runs."
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of tilt-series to return (default: 10).",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "description": "Number of tilt-series to skip for pagination (default: 0).",
          "default": 0
        }
      },
      "required": [
        "operation"
      ]
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
