      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Trait or phenotype name to search for in OpenGWAS (e.g., 'body mass index', 'coronary heart disease', 'type 2 diabetes', 'blood pressure')."
        }
      },
      "required": [
        "query"
