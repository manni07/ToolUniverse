[
  {
    "name": "EpiGraphDB_get_mendelian_randomization",
    "description": "Get Mendelian Randomization (MR) evidence for a causal relationship between an exposure trait and an outcome trait using IEU OpenGWAS data. Returns MR estimates (beta, SE, p-value) from multiple instruments/methods. Example: exposure='Body mass index', outcome='Coronary heart disease' returns causal effect estimates.",
    "parameter": {
      "type": "object",
      "properties": {
        "exposure_trait": {
          "type": "string",
          "description": "GWAS trait name for the exposure (e.g., 'Body mass index', 'LDL cholesterol', 'Type 2 diabetes'). Use EpiGraphDB_search_opengwas to find exact trait names."
        },
        "outcome_trait": {
          "type": "string",
          "description": "GWAS trait name for the outcome (e.g., 'Coronary heart disease', 'Stroke', 'Alzheimer disease'). Use EpiGraphDB_search_opengwas to find exact trait names."
        },
        "pval_threshold": {
          "type": "number",
          "description": "P-value threshold for instrument selection (default 1e-5).",
          "default": 1e-05
        }
      },
      "required": [
        "exposure_trait",
        "outcome_trait"
      ]
    },
    "fields": {
      "operation": "mr"
    },
    "type": "EpiGraphDBTool",
    "test_examples": [
      {
        "exposure_trait": "Body mass index",
        "outcome_trait": "Coronary heart disease",
        "pval_threshold": 1e-05
      },
      {
        "exposure_trait": "LDL cholesterol",
        "outcome_trait": "Coronary heart disease",
        "pval_threshold": 1e-05
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "mr_results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "exposure_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "exposure_trait": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "outcome_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "outcome_trait": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "beta": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "se": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "pval": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "method": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "moescore": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                }
              }
            },
            "total_count": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "label": [
      "EpiGraphDB",
      "Mendelian Randomization",
      "GWAS",
      "Causal Inference"
    ],
    "metadata": {
      "tags": [
        "mendelian_randomization",
        "causal_inference",
        "gwas",
        "epidemiology"
      ],
      "estimated_execution_time": "5-15 seconds"
    }
