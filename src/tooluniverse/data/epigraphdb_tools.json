  {
    "name": "EpiGraphDB_get_genetic_correlations",
    "description": "Get strong genetic correlations (|rg| > 0.8) between a GWAS trait and other traits in the IEU OpenGWAS database, indicating shared genetic architecture. NOTE: the genetic-correlation graph is sparse and matches exact, case-sensitive trait labels, so many common traits (e.g. 'Body mass index') return no rows even though they exist in OpenGWAS — an empty result means 'no strong-rg edge in the graph', not 'no shared genetics'. Genetic correlation is NOT causal evidence; use EpiGraphDB_get_mendelian_randomization for causality. Example traits with data: 'Waist circumference', 'Hip circumference', 'Body fat percentage'.",
    "parameter": {
      "type": "object",
      "properties": {
        "trait": {
          "type": "string",
          "description": "Exact, case-sensitive GWAS trait label (e.g., 'Waist circumference', 'Hip circumference'). Many labels have no node in the sparse genetic-correlation graph and return empty."
        },
        "pval_threshold": {
          "type": "number",
          "description": "Accepted for compatibility but NOT applied — the endpoint always returns the fixed |rg| > 0.8 set.",
          "default": 0.05
        }
      },
      "required": [
        "trait"
      ]
    },
    "fields": {
      "operation": "genetic_cor"
    },
    "type": "EpiGraphDBTool",
    "test_examples": [
      {
        "trait": "Waist circumference"
      },
      {
        "trait": "Hip circumference"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "correlations": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "trait1_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "trait1_trait": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "trait2_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "trait2_trait": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "rg": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "rg_pval": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                }
              }
            },
            "total_count": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "label": [
      "EpiGraphDB",
      "GWAS",
      "Genetic Correlation"
    ],
    "metadata": {
      "tags": [
        "genetic_correlation",
        "gwas",
        "shared_genetics",
        "epidemiology"
      ],
      "estimated_execution_time": "5-15 seconds"
    }
  },
  {
    "name": "EpiGraphDB_get_drugs_for_trait",
    "description": "Find drugs that target genes associated with a GWAS risk factor trait. Uses genetic evidence to identify drug repurposing candidates. Returns drugs whose target genes are significantly associated with the trait via GWAS. Example: 'LDL cholesterol' returns statins (targeting HMGCR), PCSK9 inhibitors, etc.",
    "parameter": {
      "type": "object",
      "properties": {
        "trait": {
          "type": "string",
          "description": "GWAS risk factor trait name (e.g., 'LDL cholesterol', 'Body mass index', 'C-reactive protein', 'Systolic blood pressure')."
        },
        "pval_threshold": {
          "type": "number",
          "description": "GWAS p-value threshold for gene-trait associations (default 1e-4).",
          "default": 0.0001
        }
      },
      "required": [
        "trait"
      ]
    },
    "fields": {
      "operation": "drugs_risk_factors"
    },
    "type": "EpiGraphDBTool",
    "test_examples": [
      {
        "trait": "LDL cholesterol",
        "pval_threshold": 0.0001
