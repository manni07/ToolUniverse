          "type": [
            "string",
            "null"
          ],
          "description": "Collection name to filter by (e.g., 'TCGA-GBM')"
        },
        "Modality": {
          "type": [
            "string",
            "null"
          ],
          "description": "Imaging modality to filter by (e.g., 'CT', 'MR')"
        }
      }
    },
    "fields": {
      "endpoint": "https://services.cancerimagingarchive.net/nbia-api/services/v1/getBodyPartValues"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "Modality": "CT"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of body part objects",
          "items": {
            "type": "object"
          }
