  {
    "name": "GDC_get_mutation_frequency",
    "type": "GDCMutationFrequencyTool",
    "description": "Get pan-cancer mutation frequency statistics for a gene across all TCGA/GDC cancer projects. Returns total SSM occurrence count (no per-project breakdown — use GDC_get_ssm_by_gene with project_id for cancer-specific data). Answers 'How often is this gene mutated across all cancers?'",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_symbol": {
          "type": "string",
          "description": "Gene symbol (e.g., 'TP53', 'KRAS', 'EGFR')"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol alias \u2014 alternative to gene_symbol"
        }
      },
      "required": [
        "gene_symbol"
      ],
      "additionalProperties": false
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "gene": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "test_examples": [
      {
        "gene_symbol": "TP53"
      },
      {
        "gene_symbol": "KRAS"
      }
    ],
    "label": [
      "GDC",
      "Frequency",
      "Statistics"
    ],
    "metadata": {
      "tags": [
        "mutation_frequency",
        "statistics",
        "pan_cancer"
      ],
      "estimated_execution_time": "< 3 seconds"
    }
  },
  {
    "name": "GDC_get_mutation_frequency_by_project",
    "type": "GDCMutationFreqByProjectTool",
    "description": "Get per-project (per-cancer-type) somatic mutation frequency for a gene from NCI GDC. For each TCGA/GDC project, returns the numerator (mutated case count) AND denominator (total case count), enabling true per-cancer mutation rates. Answers 'In which cancer types is this gene most frequently mutated?' Example: gene KRAS returns CPTAC-3 mutated=510/total=3521, ALCHEMIST-ALCH mutated=391/total=3038.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_symbol": {
          "type": "string",
          "description": "Gene symbol (e.g., 'KRAS', 'TP53', 'EGFR')"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol alias — alternative to gene_symbol"
        },
        "size": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of projects to return (default 100)"
        }
      },
      "required": []
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {"type": "string", "enum": ["success"]},
            "source": {"type": "string"},
            "endpoint": {"type": "string"},
            "data": {
              "type": "object",
              "properties": {
                "gene": {"type": "string"},
                "project_count": {"type": "integer"},
                "total_mutated_cases": {"type": "integer"},
                "total_cases": {"type": "integer"},
                "projects": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "project_id": {"type": ["string", "null"]},
                      "mutated_case_count": {"type": "integer"},
                      "total_case_count": {"type": "integer"},
                      "frequency": {"type": ["number", "null"]}
                    }
                  }
                }
              }
            }
          },
          "required": ["status", "data"]
        },
        {
          "type": "object",
          "properties": {
            "status": {"type": "string", "enum": ["error"]},
            "error": {"type": "string"}
          },
          "required": ["status", "error"]
        }
      ]
    },
    "test_examples": [
      {
        "gene_symbol": "KRAS",
        "size": 5
      },
      {
        "gene_symbol": "TP53",
        "size": 5
      }
    ],
    "label": [
      "GDC",
      "Frequency",
      "Per-Project",
      "TCGA"
    ],
    "metadata": {
      "tags": [
        "mutation_frequency",
        "per_cancer",
        "per_project",
        "somatic",
        "oncogenomics"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  },
  {
    "name": "GDC_get_clinical_data",
    "type": "GDCClinicalDataTool",
    "description": "Get detailed clinical data for cancer cases from NCI GDC/TCGA. Returns demographics (gender, race, vital_status, age_at_index), diagnoses (primary_diagnosis, tumor_stage, age_at_diagnosis, days_to_last_follow_up), and treatments (therapeutic_agents, treatment_type). Filter by project, primary_site, disease_type, or vital_status.",
    "parameter": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "description": "GDC project identifier (e.g., 'TCGA-BRCA', 'TCGA-LUAD', 'TARGET-AML')"
        },
        "primary_site": {
          "type": "string",
          "description": "Primary anatomical site (e.g., 'Breast', 'Lung', 'Brain')"
        },
        "disease_type": {
          "type": "string",
          "description": "Disease type filter (e.g., 'Ductal and Lobular Neoplasms')"
        },
        "vital_status": {
          "type": "string",
          "description": "Vital status filter: 'Alive' or 'Dead'",
          "enum": ["Alive", "Dead"]
        },
        "gender": {
          "type": "string",
          "description": "Gender filter: 'female' or 'male'",
          "enum": ["female", "male"]
        },
        "size": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of cases to return (1-100)"
        },
        "offset": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Pagination offset (0-based)"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "case_id": {"type": "string"},
              "submitter_id": {"type": "string"},
              "project_id": {"type": "string"},
              "vital_status": {"type": ["string", "null"]},
              "gender": {"type": ["string", "null"]},
              "age_at_index": {"type": ["integer", "null"]},
              "days_to_death": {"type": ["integer", "null"]},
              "diagnoses": {"type": "array"},
              "treatments": {"type": "array"}
            }
          }
        },
        "pagination": {
          "type": "object",
          "properties": {
            "total": {"type": "integer"},
            "count": {"type": "integer"}
          }
        }
      }
    },
    "test_examples": [
      {
        "project_id": "TCGA-BRCA",
        "size": 2
      },
      {
        "project_id": "TCGA-LUAD",
        "vital_status": "Dead",
        "size": 2
      },
      {
        "primary_site": "Brain",
        "size": 2
      }
    ],
    "label": [
      "GDC",
      "Clinical",
      "TCGA",
      "Demographics",
      "Survival"
    ],
    "metadata": {
      "tags": [
        "clinical_data",
        "demographics",
        "survival",
        "diagnoses",
        "treatments",
        "oncogenomics"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  },
  {
    "name": "GDC_get_survival",
    "type": "GDCSurvivalTool",
    "description": "Get Kaplan-Meier survival data for a GDC/TCGA cancer cohort. Returns time-to-event data with censoring status and survival estimates for each patient. Filter by project and optionally by gene mutation status. Use for overall survival analysis of TCGA cancer types.",
    "parameter": {
      "type": "object",
      "properties": {
        "project_id": {
          "type": "string",
          "description": "GDC project identifier (e.g., 'TCGA-BRCA', 'TCGA-LUAD', 'TCGA-GBM')"
        },
        "gene_symbol": {
          "type": "string",
          "description": "Optional: gene symbol to filter cases with mutations in this gene (e.g., 'TP53', 'KRAS')"
        }
      },
      "required": ["project_id"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "project_id": {"type": "string"},
        "gene_symbol": {"type": ["string", "null"]},
        "total_donors": {"type": "integer"},
        "alive_censored": {"type": "integer"},
        "deceased": {"type": "integer"},
        "max_follow_up_days": {"type": "number"},
        "median_follow_up_days": {"type": "number"},
        "donors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": {"type": "number"},
              "censored": {"type": "boolean"},
              "survivalEstimate": {"type": "number"},
              "id": {"type": "string"},
              "submitter_id": {"type": "string"}
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "project_id": "TCGA-BRCA"
      },
      {
        "project_id": "TCGA-LUAD"
      },
      {
        "project_id": "TCGA-BRCA",
        "gene_symbol": "TP53"
      }
    ],
    "label": [
      "GDC",
      "Survival",
      "Kaplan-Meier",
      "TCGA"
    ],
    "metadata": {
      "tags": [
        "survival_analysis",
        "kaplan_meier",
        "overall_survival",
        "oncogenomics",
        "prognosis"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  }
]
