                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Human-readable name of the subject"
                  },
                  "target_id": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "CURIE of the object node (e.g., NCBIGene:7076)"
                  },
                  "target_name": {
                    "type": [
                      "string",
