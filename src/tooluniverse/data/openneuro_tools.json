[
  {
    "name": "OpenNeuro_list_datasets",
    "description": "List publicly available neuroimaging datasets on OpenNeuro. OpenNeuro hosts 1000+ BIDS-formatted brain imaging datasets (fMRI, MRI, EEG, MEG, PET). Returns dataset metadata including modalities, subject counts, file counts, download statistics. Supports cursor-based pagination. Use after parameter for next page.",
    "parameter": {
      "type": "object",
      "properties": {
        "first": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of datasets to return (default 10, max 25)"
        },
        "after": {
          "type": [
            "string",
            "null"
          ],
          "description": "Cursor for pagination - use endCursor from previous response"
        }
      }
    },
    "query_schema": "query ListDatasets($first: Int, $after: String) {\n  datasets(first: $first, after: $after) {\n    edges {\n      node {\n        id\n        created\n        name\n        public\n        publishDate\n        analytics { downloads views }\n        latestSnapshot {\n          id\n          summary { modalities subjects totalFiles size primaryModality }\n          description { Name BIDSVersion License Authors DatasetDOI }\n        }\n      }\n    }\n    pageInfo { hasNextPage endCursor }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "first": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with datasets list and pagination info",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "datasets": {
                  "type": "object",
                  "properties": {
                    "edges": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "node": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": ["string", "null"]
                              },
                              "public": {
                                "type": ["boolean", "null"]
                              },
                              "analytics": {
                                "type": ["object", "null"]
                              },
                              "latestSnapshot": {
                                "type": ["object", "null"]
                              }
                            }
                          }
                        }
                      }
                    },
                    "pageInfo": {
                      "type": ["object", "null"]
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_get_dataset",
    "description": "Get detailed information about a specific neuroimaging dataset on OpenNeuro by its dataset ID (e.g., 'ds000114', 'ds000224'). Returns full metadata including modalities, tasks, subject list, BIDS version, authors, DOI, README, and download statistics.",
    "parameter": {
      "type": "object",
      "properties": {
        "datasetId": {
          "type": "string",
          "description": "OpenNeuro dataset ID (e.g., 'ds000114', 'ds000224', 'ds003097')"
        }
      },
      "required": [
        "datasetId"
      ]
    },
    "query_schema": "query GetDataset($datasetId: ID!) {\n  dataset(id: $datasetId) {\n    id\n    created\n    name\n    public\n    publishDate\n    analytics { downloads views }\n    latestSnapshot {\n      id\n      tag\n      created\n      size\n      summary { modalities subjects tasks totalFiles size primaryModality sessions }\n      description { Name BIDSVersion License Authors Funding ReferencesAndLinks DatasetDOI EthicsApprovals }\n      readme\n    }\n    stars { userId }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "datasetId": "ds000114"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with dataset details",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "dataset": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": ["string", "null"]
                    },
                    "public": {
                      "type": ["boolean", "null"]
                    },
                    "publishDate": {
                      "type": ["string", "null"]
                    },
                    "analytics": {
                      "type": ["object", "null"]
                    },
                    "latestSnapshot": {
                      "type": ["object", "null"],
                      "properties": {
                        "summary": {
                          "type": ["object", "null"]
                        },
                        "description": {
                          "type": ["object", "null"]
                        },
                        "readme": {
                          "type": ["string", "null"]
                        }
                      }
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_get_dataset_snapshots",
    "description": "Get all version snapshots of a specific dataset on OpenNeuro. Returns the snapshot id, tag, and creation date for every published version of the dataset. For per-snapshot summary statistics (modalities, subjects, file counts), use OpenNeuro_get_dataset, which returns the latest snapshot's summary.",
    "parameter": {
      "type": "object",
      "properties": {
        "datasetId": {
          "type": "string",
          "description": "OpenNeuro dataset ID (e.g., 'ds000114')"
        }
      },
      "required": [
        "datasetId"
      ]
    },
    "query_schema": "query GetSnapshots($datasetId: ID!) {\n  dataset(id: $datasetId) {\n    id\n    name\n    snapshots {\n      id\n      tag\n      created\n    }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "datasetId": "ds000114"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with dataset snapshots",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "dataset": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": ["string", "null"]
                    },
                    "snapshots": {
                      "type": ["array", "null"],
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "tag": {
                            "type": "string"
                          },
                          "created": {
                            "type": ["string", "null"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_search_by_modality",
    "description": "Search OpenNeuro neuroimaging datasets filtered by imaging modality. Supported modalities include: 'MRI' (structural and functional MRI), 'EEG' (electroencephalography), 'iEEG' (intracranial EEG), 'MEG' (magnetoencephalography), 'PET' (positron emission tomography). Returns dataset IDs, names, creation dates, and total count of matching datasets. OpenNeuro hosts 1600+ BIDS-formatted brain imaging datasets.",
    "parameter": {
      "type": "object",
      "properties": {
        "modality": {
          "type": "string",
          "description": "Imaging modality to filter by. Options: 'MRI', 'EEG', 'iEEG', 'MEG', 'PET'."
        },
        "first": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of datasets to return (default 10, max 25)"
        }
      },
      "required": [
        "modality"
      ]
    },
    "query_schema": "query SearchByModality($first: Int, $modality: String) {\n  datasets(first: $first, modality: $modality, orderBy: {created: descending}) {\n    edges {\n      node {\n        id\n        created\n        name\n        public\n      }\n    }\n    pageInfo { count }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "modality": "EEG",
        "first": 5
      },
      {
        "modality": "MRI",
        "first": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with filtered datasets",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "datasets": {
                  "type": "object",
                  "properties": {
                    "edges": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "node": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": ["string", "null"]
                              },
                              "created": {
                                "type": ["string", "null"]
                              },
                              "public": {
                                "type": ["boolean", "null"]
                              }
                            }
                          }
                        }
                      }
                    },
                    "pageInfo": {
                      "type": ["object", "null"],
                      "properties": {
                        "count": {
                          "type": ["integer", "null"],
                          "description": "Total matching datasets"
                        }
                      }
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_get_snapshot_files",
    "description": "List the files in a specific version (snapshot) of an OpenNeuro dataset, with direct keyless download URLs for each file. Unlike OpenNeuro_get_dataset (which returns only metadata), this returns the actual file manifest needed to retrieve the imaging data: filename, size in bytes, directory flag, and one or more object download URLs. Requires the dataset ID and a snapshot tag (get available tags from OpenNeuro_get_dataset_snapshots).",
    "parameter": {
      "type": "object",
      "properties": {
        "datasetId": {
          "type": "string",
          "description": "OpenNeuro dataset ID (e.g., 'ds000001')"
        },
        "tag": {
          "type": "string",
          "description": "Snapshot tag / version, as returned by OpenNeuro_get_dataset_snapshots (e.g., '00006')"
        }
      },
      "required": [
        "datasetId",
        "tag"
      ]
    },
    "query_schema": "query GetSnapshotFiles($datasetId: ID!, $tag: String!) {\n  snapshot(datasetId: $datasetId, tag: $tag) {\n    id\n    tag\n    files {\n      filename\n      size\n      directory\n      urls\n    }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "datasetId": "ds000001",
        "tag": "00006"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with the snapshot file manifest",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "snapshot": {
                  "type": ["object", "null"],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    },
                    "files": {
                      "type": ["array", "null"],
                      "items": {
                        "type": "object",
                        "properties": {
                          "filename": {
                            "type": "string"
                          },
                          "size": {
                            "type": ["integer", "null"]
                          },
                          "directory": {
                            "type": ["boolean", "null"]
                          },
                          "urls": {
                            "type": ["array", "null"],
                            "items": {
                              "type": "string"
                            },
                            "description": "Direct keyless download URLs for the file object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_get_snapshot_validation",
    "description": "Get BIDS validation results for a specific version (snapshot) of an OpenNeuro dataset. Returns whether the dataset passes the BIDS validator and how many errors/warnings it has, via two fields: issuesStatus (a deduplicated summary count of errors and warnings) and validation (raw validator error/warning counts). Use this to assess dataset quality/validity before downloading. Requires the dataset ID and a snapshot tag (from OpenNeuro_get_dataset_snapshots).",
    "parameter": {
      "type": "object",
      "properties": {
        "datasetId": {
          "type": "string",
          "description": "OpenNeuro dataset ID (e.g., 'ds000001')"
        },
        "tag": {
          "type": "string",
          "description": "Snapshot tag / version (e.g., '00006')"
        }
      },
      "required": [
        "datasetId",
        "tag"
      ]
    },
    "query_schema": "query GetSnapshotValidation($datasetId: ID!, $tag: String!) {\n  snapshot(datasetId: $datasetId, tag: $tag) {\n    id\n    tag\n    issuesStatus {\n      errors\n      warnings\n    }\n    validation {\n      errors\n      warnings\n    }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "datasetId": "ds000001",
        "tag": "00006"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with BIDS validation status",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "snapshot": {
                  "type": ["object", "null"],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    },
                    "issuesStatus": {
                      "type": ["object", "null"],
                      "properties": {
                        "errors": {
                          "type": ["integer", "null"]
                        },
                        "warnings": {
                          "type": ["integer", "null"]
                        }
                      }
                    },
                    "validation": {
                      "type": ["object", "null"],
                      "properties": {
                        "errors": {
                          "type": ["integer", "null"]
                        },
                        "warnings": {
                          "type": ["integer", "null"]
                        }
                      }
                    }
                  }
                }
              }
            },
            "extensions": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenNeuro_advanced_search",
    "description": "Faceted search across all OpenNeuro datasets plus the archive-wide total participant count. Returns participantCount (total number of subjects across the whole OpenNeuro archive) and advancedSearch with pageInfo.count (number of datasets matching the facet filters) and a best-effort list of matching dataset IDs. Pass any combination of flat facet arguments (species, sex, diagnosis, modality, tasks, keywords, scannerManufacturers, tracerNames, studyDomains, ageRange, subjectCountRange, authors, bodyParts, bidsDatasetType, tracerRadionuclides); omit all to count the whole archive. Note: some matched datasets are not anonymously readable, so a few edges may be omitted, but the counts remain accurate.",
    "parameter": {
      "type": "object",
      "properties": {
        "species": {
          "type": ["string", "null"],
          "description": "Species facet (e.g., 'human')"
        },
        "sex": {
          "type": ["string", "null"],
          "description": "Participant sex facet (e.g., 'Male', 'Female')"
        },
        "diagnosis": {
          "type": ["string", "null"],
          "description": "Clinical diagnosis facet"
        },
        "modality": {
          "type": ["string", "null"],
          "description": "Imaging modality facet (e.g., 'MRI', 'EEG', 'PET')"
        },
        "tasks": {
          "type": ["string", "null"],
          "description": "Task name facet"
        },
        "keywords": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          },
          "description": "Keyword facets (list of strings)"
        },
        "scannerManufacturers": {
          "type": ["string", "null"],
          "description": "Scanner manufacturer facet (e.g., 'Siemens')"
        },
        "tracerNames": {
          "type": ["string", "null"],
          "description": "PET tracer name facet"
        },
        "tracerRadionuclides": {
          "type": ["string", "null"],
          "description": "PET tracer radionuclide facet"
        },
        "studyDomains": {
          "type": ["string", "null"],
          "description": "Study domain facet"
        },
        "bodyParts": {
          "type": ["string", "null"],
          "description": "Body part facet"
        },
        "authors": {
          "type": ["string", "null"],
          "description": "Author name facet"
        },
        "bidsDatasetType": {
          "type": ["string", "null"],
          "description": "BIDS dataset type facet (e.g., 'raw', 'derivative')"
        },
        "ageRange": {
          "type": ["array", "null"],
          "items": {
            "type": "integer"
          },
          "description": "Participant age range as [min, max]"
        },
        "subjectCountRange": {
          "type": ["array", "null"],
          "items": {
            "type": "integer"
          },
          "description": "Subject-count range as [min, max]"
        },
        "first": {
          "type": ["integer", "null"],
          "description": "Number of matching datasets to return (default 10, max 25)"
        }
      }
    },
    "query_schema": "query AdvancedSearch($query: DatasetSearchInput!, $first: Int) {\n  participantCount\n  advancedSearch(query: $query, first: $first) {\n    pageInfo {\n      count\n    }\n    edges {\n      node {\n        id\n      }\n    }\n  }\n}",
    "fields": {},
    "type": "OpenNeuroTool",
    "test_examples": [
      {
        "species": "human",
        "first": 3
      },
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GraphQL response with participant count and faceted dataset search",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "participantCount": {
                  "type": ["integer", "null"],
                  "description": "Total subject count across the whole OpenNeuro archive"
                },
                "advancedSearch": {
                  "type": ["object", "null"],
                  "properties": {
                    "pageInfo": {
                      "type": ["object", "null"],
                      "properties": {
                        "count": {
                          "type": ["integer", "null"],
                          "description": "Number of datasets matching the facet filters"
                        }
                      }
                    },
                    "edges": {
                      "type": ["array", "null"],
                      "items": {
                        "type": ["object", "null"],
                        "properties": {
                          "node": {
                            "type": ["object", "null"],
                            "properties": {
                              "id": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": ["object", "null"]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "description": "Error message if the request failed"
            }
          },
          "required": ["error"]
        }
      ]
    }
  }
]
