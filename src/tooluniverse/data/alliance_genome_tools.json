  {
    "name": "Alliance_get_alleles_and_models",
    "description": "Get alleles/variants and affected genomic models (mutant strains) for a gene via the Alliance of Genome Resources (mouse/MGI, frog/Xenbase, and other members). Returns allele/variant records with HGVS genomic locations and disease/phenotype flags, plus affected genomic models (genotypes/strains). Example: MGI:97490 (Pax6) returns variant_summary records such as rs231853465 (NC_000068.8:g.105516528T>C) and models such as AffectedGenomicModel MGI:2680573.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "Alliance gene ID with member prefix, e.g. 'MGI:97490' (Pax6), 'HGNC:8620'."
