[
  {
    "name": "Alliance_get_gene",
    "description": "Get detailed gene information from the Alliance of Genome Resources, which integrates data from 7 model organism databases (SGD, FlyBase, WormBase, ZFIN, RGD, MGI, Xenbase) plus human. Returns gene symbol, name, species, synopsis, synonyms, genomic location, and cross-references. Example: 'HGNC:6081' returns insulin gene info.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "Alliance gene ID with source prefix. Examples: 'HGNC:6081' (human INS), 'MGI:98834' (mouse Trp53), 'FB:FBgn0003996' (fly w), 'SGD:S000000259' (yeast GAL4), 'ZFIN:ZDB-GENE-990415-8' (zebrafish pax2a), 'WB:WBGene00006763' (worm unc-13)."
        }
      },
      "required": [
        "gene_id"
      ]
    },
    "fields": {
      "endpoint_type": "gene_detail"
    },
    "type": "AllianceGenomeTool",
    "test_examples": [
      {
        "gene_id": "HGNC:6081"
      },
      {
        "gene_id": "MGI:98834"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "id": {
