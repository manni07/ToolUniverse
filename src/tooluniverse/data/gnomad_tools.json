        "gene_symbol": {
          "type": "string",
          "description": "Gene symbol (e.g., 'BRCA1')."
        },
        "gene_id": {
          "type": "string",
          "description": "Ensembl gene ID (e.g., 'ENSG00000012048')."
        },
        "reference_genome": {
          "type": "string",
          "enum": [
            "GRCh37",
            "GRCh38"
          ],
          "default": "GRCh38",
          "description": "Reference genome."
        }
      },
      "oneOf": [
        {
          "required": [
            "gene_symbol"
