[
  {
    "type": "CompoundVariantAnnotationTool",
    "name": "annotate_variant_multi_source",
    "description": "Annotate a genetic variant from ClinVar, gnomAD, CIViC, and UniProt in a single call. Returns pathogenicity classification, population constraints, clinical evidence, and protein function. Use when you need comprehensive variant interpretation from multiple databases at once.",
    "parameter": {
      "type": "object",
      "properties": {
        "variant": {
          "type": ["string", "null"],
          "description": "Variant name (e.g., 'BRAF V600E', 'TP53 R175H'). Gene symbol + amino acid change."
        },
        "gene": {
          "type": ["string", "null"],
          "description": "Gene symbol (e.g., 'BRCA1'). Used for gnomAD/CIViC lookup."
        },
        "rsid": {
          "type": ["string", "null"],
          "description": "dbSNP rsID (e.g., 'rs113488022')."
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "status": {"const": "success"},
            "data": {
              "type": "object",
              "properties": {
                "query": {"type": "object"},
                "sources_queried": {"type": "array"},
                "sources_failed": {"type": "array"},
                "summary": {"type": "object"},
                "annotations": {"type": "object"}
              }
            }
          }
        },
        {
          "properties": {
            "status": {"const": "error"},
            "error": {"type": "string"}
          }
        }
      ]
    },
    "test_examples": [
      {"variant": "BRAF V600E"},
      {"gene": "BRCA1"},
      {"rsid": "rs113488022"}
    ]
  }
]
