[
  {
    "name": "UCSC_search",
    "description": "Search the UCSC Genome Browser for genes, transcripts, or genomic features by name. Returns position matches across tracks (MANE, RefSeq, GENCODE, HGNC, etc.) for a given genome assembly. Supports searching for gene symbols, transcript IDs, SNP rsIDs, or chromosomal bands. Example: searching 'TP53' in hg38 returns chr17:7668421-7687490 from MANE Select and other tracks.",
    "parameter": {
      "type": "object",
      "properties": {
        "search_term": {
          "type": "string",
          "description": "Gene symbol, transcript ID, SNP rsID, or genomic feature to search. Examples: 'TP53', 'BRCA1', 'rs429358', 'ENST00000269305'."
        },
        "genome": {
          "type": "string",
          "description": "UCSC genome assembly identifier. Default: 'hg38'. Others: 'hg19', 'mm10', 'mm39', 'dm6', 'ce11', 'danRer11', 'sacCer3'."
        }
      },
      "required": [
        "search_term"
      ]
    },
    "fields": {
      "endpoint_type": "search"
    },
    "type": "UCSCGenomeTool",
    "test_examples": [
      {
        "search_term": "TP53",
        "genome": "hg38"
      },
      {
        "search_term": "BRCA1",
        "genome": "hg38"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "genome": {
                  "type": "string"
                },
                "search_term": {
                  "type": "string"
                },
                "match_count": {
                  "type": "integer"
                },
                "matches": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "track": {
                        "type": "string"
                      },
                      "track_description": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "position": {
                        "type": "string"
                      },
                      "name": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "transcript_id": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "UCSC_list_tracks",
    "description": "Discover available UCSC Genome Browser annotation tracks for a genome assembly, and inspect a track's column schema. With only 'genome' set, returns the list of leaf tracks (each with track name, type, shortLabel, longLabel, parent) so you can find valid track names to pass to UCSC_get_track (there are tens of thousands, e.g. dbSnp155, dbSnp155ClinVar, dbSnp155Common, knownGene, ncbiRefSeq, encodeCcreCombined). Use 'name_filter' to narrow the list by substring (matched against track name, shortLabel, longLabel). When 'track' is also provided, returns that track's column schema instead (column name, sqlType, jsonType, description) from the list/schema endpoint. Example: genome 'hg38' returns 23000+ tracks; genome 'hg38' + track 'knownGene' returns its 27 columns (chrom, chromStart, ...).",
    "parameter": {
      "type": "object",
      "properties": {
        "genome": {
          "type": "string",
          "description": "UCSC genome assembly identifier. Examples: 'hg38', 'hg19', 'mm39', 'mm10', 'dm6', 'danRer11'."
        },
        "track": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional. When set, return this track's column schema instead of the track list. Example: 'knownGene', 'dbSnp155', 'ncbiRefSeq'."
        },
        "name_filter": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional substring filter (case-insensitive) applied to track name/shortLabel/longLabel when listing tracks. Example: 'dbSnp', 'gencode', 'clinvar'."
        },
        "max_tracks": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of tracks to return when listing (default 500). The total matched count is always reported in track_count."
        }
      },
      "required": [
        "genome"
      ]
    },
    "fields": {
      "endpoint_type": "list_tracks"
    },
    "type": "UCSCGenomeTool",
    "test_examples": [
      {
        "genome": "hg38",
        "name_filter": "dbSnp155",
        "max_tracks": 10
      },
      {
        "genome": "hg38",
        "track": "knownGene"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "genome": {
                  "type": "string"
                },
                "name_filter": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "track_count": {
                  "type": "integer"
                },
                "returned_count": {
                  "type": "integer"
                },
                "tracks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "track": {
                        "type": "string"
                      },
                      "type": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "short_label": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "long_label": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "parent": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "group": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                },
                "track": {
                  "type": "string"
                },
                "track_type": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "column_count": {
                  "type": "integer"
                },
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "sqlType": {
                        "type": "string"
                      },
                      "jsonType": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "UCSC_get_sequence",
    "description": "Get DNA sequence from the UCSC Genome Browser for a specified genomic region. Returns the nucleotide sequence for a given chromosome, start, and end position in a genome assembly. Useful for primer design, sequence analysis, and regulatory element inspection. Example: hg38, chr17, start=7668421, end=7668521 returns 100bp of TP53 sequence.",
    "parameter": {
      "type": "object",
      "properties": {
        "genome": {
          "type": "string",
          "description": "UCSC genome assembly identifier. Examples: 'hg38' (human), 'mm39' (mouse), 'dm6' (fly), 'sacCer3' (yeast)."
        },
        "chrom": {
          "type": "string",
          "description": "Chromosome name. Examples: 'chr1', 'chr17', 'chrX', 'chrM'."
        },
        "start": {
          "type": "integer",
          "description": "0-based start position (inclusive). Example: 7668421."
        },
        "end": {
          "type": "integer",
          "description": "End position (exclusive). Must be > start and span <= 100000 bp. Example: 7668521."
        }
      },
      "required": [
        "genome",
        "chrom",
        "start",
        "end"
      ]
    },
    "fields": {
      "endpoint_type": "get_sequence"
    },
    "type": "UCSCGenomeTool",
    "test_examples": [
      {
        "genome": "hg38",
        "chrom": "chr17",
        "start": 7668421,
        "end": 7668521
      },
      {
        "genome": "hg38",
        "chrom": "chrM",
        "start": 4321,
        "end": 5678
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "genome": {
                  "type": "string"
                },
                "chrom": {
                  "type": "string"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                },
                "length": {
                  "type": "integer"
                },
                "dna": {
                  "type": "string"
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "UCSC_get_track",
    "description": "Get annotation track data from the UCSC Genome Browser for a specified genomic region. Retrieves features like genes, regulatory elements, conservation scores, variants, or repeats from any of UCSC's 370+ tracks. Use UCSC_search first to find the genomic coordinates of your gene of interest. Example: track 'knownGene' on hg38 chr17:7668421-7687490 returns GENCODE gene annotations for the TP53 region.",
    "parameter": {
      "type": "object",
      "properties": {
        "genome": {
          "type": "string",
          "description": "UCSC genome assembly. Examples: 'hg38', 'hg19', 'mm39'."
        },
        "track": {
          "type": "string",
          "description": "Track name. Common tracks: 'knownGene' (GENCODE genes), 'ncbiRefSeq' (RefSeq), 'snp151' (dbSNP), 'encodeCcreCombined' (ENCODE cCREs), 'phastCons100way' (conservation), 'rmsk' (repeats)."
        },
        "chrom": {
          "type": "string",
          "description": "Chromosome name. Examples: 'chr1', 'chr17', 'chrX'."
        },
        "start": {
          "type": "integer",
          "description": "0-based start position (inclusive)."
        },
        "end": {
          "type": "integer",
          "description": "End position (exclusive). Must be > start."
        },
        "maxItemsOutput": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of items to return. Default: 100. Set to limit large result sets."
        }
      },
      "required": [
        "genome",
        "track",
        "chrom",
        "start",
        "end"
      ]
    },
    "fields": {
      "endpoint_type": "get_track"
    },
    "type": "UCSCGenomeTool",
    "test_examples": [
      {
        "genome": "hg38",
        "track": "knownGene",
        "chrom": "chr17",
        "start": 7668421,
        "end": 7687490,
        "maxItemsOutput": 10
      },
      {
        "genome": "hg38",
        "track": "encodeCcreCombined",
        "chrom": "chr1",
        "start": 11000,
        "end": 15000,
        "maxItemsOutput": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "genome": {
                  "type": "string"
                },
                "track": {
                  "type": "string"
                },
                "track_type": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "chrom": {
                  "type": "string"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                },
                "item_count": {
                  "type": "integer"
                },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
]
