                      }
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                },
                "config": {
                  "type": "object",
                  "properties": {
                    "iiif_url": {
                      "type": "string"
                    },
                    "website_url": {
                      "type": "string"
                    }
                  }
                }
              }
