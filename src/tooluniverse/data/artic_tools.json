[
  {
    "name": "ArtIC_search_artworks",
    "description": "Search the Art Institute of Chicago's collection of over 100,000 artworks using its public API. Returns artwork titles, artists, dates, mediums, and collection links. No authentication required. The collection includes Impressionist paintings (Seurat, Monet, Picasso), ancient art, photography, prints, and decorative arts. Useful for art research, museum data analysis, and cultural heritage studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query. Examples: 'monet water lilies', 'picasso cubism', 'ancient egypt', 'japanese woodblock', 'american landscape'"
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of results (1-100). Default: 10"
        },
        "fields": {
          "type": [
            "string",
            "null"
          ],
          "description": "Comma-separated fields to return. Default: 'id,title,artist_display,date_display,medium_display'. Other options: image_id, dimensions, artwork_type_title, style_title, classification_title"
        }
      },
      "required": [
        "q"
      ]
    },
    "fields": {
      "endpoint": "https://api.artic.edu/api/v1/artworks/search",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "q": "monet water lilies",
        "limit": 5
      },
      {
        "q": "picasso cubism",
        "limit": 5
      },
      {
        "q": "ancient egypt",
        "limit": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "preference": {
                  "type": "null"
                },
                "pagination": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": [
                        "integer",
                        "number"
                      ]
                    },
                    "limit": {
                      "type": [
                        "integer",
                        "number"
                      ]
                    },
                    "offset": {
                      "type": [
                        "integer",
                        "number"
                      ]
                    },
                    "total_pages": {
                      "type": [
                        "integer",
                        "number"
                      ]
                    },
                    "current_page": {
                      "type": [
                        "integer",
                        "number"
                      ]
                    }
                  }
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_score": {
                        "type": "number"
                      },
                      "id": {
                        "type": [
                          "integer",
                          "number"
                        ]
                      },
                      "api_model": {
                        "type": "string"
                      },
                      "api_link": {
                        "type": "string"
                      },
                      "is_boosted": {
                        "type": "boolean"
                      },
                      "title": {
                        "type": "string"
                      },
                      "thumbnail": {
                        "type": "object",
                        "properties": {
                          "lqip": {
                            "type": "string"
                          },
                          "width": {
                            "type": [
                              "integer",
                              "number"
                            ]
                          },
                          "height": {
                            "type": [
                              "integer",
                              "number"
                            ]
                          },
                          "alt_text": {
                            "type": "string"
                          }
                        }
                      },
                      "timestamp": {
                        "type": "string"
                      }
                    }
                  }
                },
                "info": {
                  "type": "object",
                  "properties": {
                    "license_text": {
                      "type": "string"
                    },
                    "license_links": {
                      "type": "array",
