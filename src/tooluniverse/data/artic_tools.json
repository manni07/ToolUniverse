            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  {
    "name": "ArtIC_get_artwork",
    "description": "Get detailed information about a specific artwork from the Art Institute of Chicago collection by its numeric ID. Returns full metadata including title, artist, date, medium, dimensions, provenance, exhibition history, and IIIF image URL. No authentication required. Use ArtIC_search_artworks to find artwork IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "Artwork ID from Art Institute of Chicago. Examples: 27992 (A Sunday on La Grande Jatte), 16568 (The Bedroom by Van Gogh), 20684 (American Gothic)"
        }
      },
      "required": [
        "id"
      ]
    },
    "fields": {
      "endpoint": "https://api.artic.edu/api/v1/artworks/{id}",
      "params": {
        "fields": "id,title,artist_display,date_display,medium_display,dimensions,image_id,description,place_of_origin,style_title,artwork_type_title,credit_line,is_public_domain"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "id": 27992
      },
      {
        "id": 16568
      },
      {
        "id": 20684
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": [
