[
  {
    "name": "ExpressionAtlas_get_baseline",
    "description": "Get baseline gene expression experiments from EBI Expression Atlas. Shows which tissues/cell types express a gene under normal conditions. Complements GTEx and HPA. No API key needed. Query by gene symbol or Ensembl ID.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., 'TP53', 'WDR7') or Ensembl ID (e.g., 'ENSG00000141510')"
        },
        "species": {
          "type": "string",
          "description": "Species name (default: 'homo sapiens'). Also supports 'mus musculus', 'rattus norvegicus', etc.",
          "default": "homo sapiens"
        }
      },
      "required": [
        "gene"
      ]
    },
    "fields": {
      "operation": "get_baseline_expression"
    },
    "type": "ExpressionAtlasTool",
    "test_examples": [
      {
        "gene": "TP53",
        "species": "homo sapiens"
      },
      {
        "gene": "BRCA1"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "gene": {
                  "type": "string"
                },
                "species": {
                  "type": "string"
                },
                "baseline_experiments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "experiment_accession": {
                        "type": "string"
                      },
                      "experiment_type": {
                        "type": "string"
                      },
                      "experiment_description": {
                        "type": "string"
                      },
                      "species": {
                        "type": "string"
                      },
                      "num_assays": {
                        "type": [
                          "integer",
                          "number"
                        ]
                      },
                      "gene_mentioned": {
                        "type": "boolean"
                      },
                      "last_update": {
                        "type": "string"
                      }
                    }
                  }
                },
                "total_baseline": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "gene_specific_count": {
                  "type": [
                    "integer",
                    "number"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    },
    "label": [
      "Expression Atlas",
      "Baseline Expression",
      "Tissue Expression"
    ],
    "metadata": {
      "tags": [
        "gene_expression",
        "baseline",
        "tissue",
        "rna_seq",
        "proteomics"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  },
  {
    "name": "ExpressionAtlas_search_differential",
    "description": "Search for differential expression experiments from EBI Expression Atlas. Find experiments where a gene is differentially expressed in disease vs. normal, treated vs. untreated, etc. Supports disease-context expression analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene": {
          "type": "string",
          "description": "Gene symbol or Ensembl ID (e.g., 'TP53', 'ENSG00000141510')"
        },
        "condition": {
          "type": "string",
          "description": "Condition/disease to filter by (e.g., 'cancer', 'inflammation', 'breast')"
        },
        "species": {
          "type": "string",
          "description": "Species name (default: 'homo sapiens')",
          "default": "homo sapiens"
        }
      }
    },
    "fields": {
      "operation": "search_differential_experiments"
    },
    "type": "ExpressionAtlasTool",
    "test_examples": [
      {
        "gene": "TP53",
        "species": "homo sapiens"
      },
      {
        "gene": "EGFR",
        "condition": "cancer"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "gene": {
                  "type": "string"
                },
                "condition": {
                  "type": "string"
                },
                "species": {
                  "type": "string"
                },
                "experiments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "experiment_accession": {
                        "type": "string"
                      },
                      "experiment_type": {
                        "type": "string"
                      },
                      "experiment_description": {
                        "type": "string"
                      },
                      "species": {
                        "type": "string"
                      },
                      "num_assays": {
                        "type": [
                          "integer",
                          "number"
                        ]
                      },
                      "gene_mentioned": {
                        "type": "boolean"
                      },
                      "factors": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "experiment_count": {
                  "type": [
                    "integer",
                    "number"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    },
    "label": [
      "Expression Atlas",
      "Differential Expression",
      "Disease Expression"
    ],
    "metadata": {
      "tags": [
        "differential_expression",
        "disease_context",
        "treatment_response"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  },
  {
