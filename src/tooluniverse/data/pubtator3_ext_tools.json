[
  {
    "name": "PubTator3_get_annotations",
    "description": "Extract biomedical entity annotations from PubMed articles using NCBI PubTator3. Given one or more PubMed IDs (PMIDs), returns text-mined entities including genes, diseases, chemicals, species, mutations, and cell lines with their normalized identifiers (NCBI Gene ID, MeSH, NCBI Taxonomy, etc.) and text positions. Useful for extracting structured biomedical knowledge from literature. Provide PMIDs as a comma-separated string.",
    "parameter": {
      "type": "object",
      "properties": {
        "pmids": {
          "type": "string",
          "description": "Comma-separated PubMed IDs (e.g., '33205991', '33205991,34234088'). Maximum ~100 PMIDs per request."
        },
        "concepts": {
          "type": "string",
          "default": "gene,disease,chemical,species,mutation,cellline",
          "description": "Comma-separated entity types to extract: gene, disease, chemical, species, mutation, cellline (default: all types)"
        }
      },
      "required": [
        "pmids"
      ]
    },
    "fields": {
      "endpoint": "https://www.ncbi.nlm.nih.gov/research/pubtator3-api/publications/export/biocjson"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "pmids": "33205991",
        "concepts": "gene,disease,chemical"
      },
      {
        "pmids": "34234088",
        "concepts": "gene,disease"
      },
      {
        "pmids": "25416956"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "PubTator3": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "_id": {
                        "type": "string"
                      },
                      "id": {
                        "type": "string"
                      },
                      "infons": {
                        "type": "object"
                      },
                      "passages": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "infons": {
                              "type": "object",
                              "properties": {
                                "journal": {
                                  "type": "string"
                                },
                                "year": {
                                  "type": "string"
                                },
                                "article-id_pmc": {
                                  "type": "string"
                                },
                                "type": {
                                  "type": "string"
                                },
                                "authors": {
                                  "type": "string"
                                }
                              }
                            },
                            "offset": {
                              "type": [
                                "integer",
                                "number"
                              ]
                            },
                            "text": {
                              "type": "string"
                            },
                            "sentences": {
                              "type": "array"
                            },
                            "annotations": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "infons": {
                                    "type": "object",
                                    "properties": {
                                      "identifier": {
                                        "type": "string"
                                      },
                                      "type": {
                                        "type": "string"
                                      },
                                      "valid": {
                                        "type": "boolean"
                                      },
                                      "normalized": {
                                        "type": "array",
                                        "items": {
                                          "type": [
                                            "integer",
                                            "number",
                                            "string"
                                          ]
                                        }
                                      },
                                      "database": {
                                        "type": "string"
                                      },
                                      "normalized_id": {
                                        "type": [
                                          "integer",
                                          "number",
                                          "string"
                                        ]
                                      },
                                      "biotype": {
                                        "type": "string"
                                      },
                                      "name": {
                                        "type": "string"
                                      },
                                      "accession": {
                                        "type": [
                                          "null",
                                          "string"
                                        ]
                                      }
                                    }
                                  },
                                  "text": {
                                    "type": "string"
                                  },
                                  "locations": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "offset": {
                                          "type": [
                                            "integer",
                                            "number"
                                          ]
                                        },
                                        "length": {
                                          "type": [
                                            "integer",
                                            "number"
                                          ]
                                        }
                                      }
                                    }
                                  }
                                }
                              }
