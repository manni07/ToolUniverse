                          "type": "string"
                        }
                      },
                      "relations_display": {
                        "type": "array"
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
