  {
    "name": "SGD_get_sequence",
    "description": "Get genomic, coding, and protein sequences plus genomic coordinates for a yeast gene from SGD (reference strain S288C). Returns the genomic DNA start/end/strand and full residue strings for genomic_dna, coding_dna, and protein. Example: S000000364 (CDC28) returns genomic_dna start=560078 end=560974 with residues 'ATGAGCGGTGAATTAGCAAAT...'.",
    "parameter": {
      "type": "object",
      "properties": {
        "sgd_id": {
          "type": "string",
          "description": "SGD locus identifier. Examples: 'S000000364' (CDC28), 'S000005564' (ACT1)."
        }
      },
      "required": [
        "sgd_id"
      ]
    },
    "fields": {
      "endpoint_type": "locus",
      "query_mode": "sequence"
    },
    "type": "SGDTool",
    "timeout": 30,
    "test_examples": [
