  {
    "name": "SGD_search",
    "description": "Search SGD across all data types (genes, GO terms, phenotypes, references, alleles, diseases, complexes, pathways). Returns matching entries with categories, descriptions, and links. Supports category filtering. Example: searching 'GAL4' finds the transcription factor gene, related references, alleles, and GO terms.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query string. Examples: 'GAL4', 'cell cycle', 'sporulation'."
        },
        "category": {
          "type": "string",
          "description": "Filter by category. Options: 'locus', 'reference', 'biological_process', 'molecular_function', 'cellular_component', 'phenotype', 'disease', 'allele', 'complex', 'pathway', 'chemical', 'strain', 'download'."
        },
        "limit": {
          "type": "integer",
          "description": "Maximum results to return (default 10, max 50)."
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset (default 0)."
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "endpoint_type": "search"
    },
    "type": "SGDTool",
    "test_examples": [
      {
        "query": "GAL4",
        "category": "locus",
        "limit": 5
      },
      {
        "query": "cell cycle",
        "category": "biological_process",
        "limit": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "href": {
                    "type": "string"
                  },
                  "aliases": {
                    "type": [
                      "array",
                      "null"
                    ]
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "total_results": {
                  "type": "integer"
                },
                "categories": {
                  "type": "object",
                  "description": "Count of results per category"
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "SGD_get_regulation",
    "description": "Get the transcriptional regulation network for a yeast gene from SGD: curated regulator->target relationships with evidence, direction, and references. Returns pairs where the queried gene is regulator or target. Example: S000000364 (CDC28) is regulated by IXR1 (S000001515) with 'DNA to cDNA expression microarray evidence', regulation_of=transcription.",
    "parameter": {
      "type": "object",
      "properties": {
        "sgd_id": {
          "type": "string",
          "description": "SGD locus identifier. Examples: 'S000000364' (CDC28), 'S000000259' (GAL4)."
        }
      },
      "required": [
        "sgd_id"
      ]
    },
    "fields": {
      "endpoint_type": "locus",
      "query_mode": "regulation"
    },
    "type": "SGDTool",
    "timeout": 30,
    "test_examples": [
      {
        "sgd_id": "S000000364"
      },
      {
        "sgd_id": "S000000259"
      }
    ],
    "return_schema": {
      "oneOf": [
