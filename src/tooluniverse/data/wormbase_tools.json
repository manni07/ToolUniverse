                          "string",
                          "null"
                        ]
                      },
                      "methods": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "nematode_ortholog_count": {
                  "type": "integer"
                },
                "nematode_orthologs": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "paralog_count": {
                  "type": "integer"
                },
                "paralogs": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
