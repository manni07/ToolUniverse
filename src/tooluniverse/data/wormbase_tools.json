  {
    "name": "WormBase_get_human_diseases",
    "description": "Get human disease models (Disease Ontology / DOID) for a C. elegans gene from WormBase, inferred by orthology to human disease genes. Accepts a WBGene ID or gene name. Example: WBGene00006818 (unc-86) is a potential model for DOID:0110546 'autosomal dominant nonsyndromic deafness 15', inferred by orthology to human HGNC:9220.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "WBGene identifier or gene name. Examples: 'WBGene00006818', 'unc-86'."
        }
      },
      "required": [
        "gene_id"
      ]
