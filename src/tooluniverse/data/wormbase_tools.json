  {
    "name": "WormBase_get_orthologs",
    "description": "Get orthologs and homologs of a C. elegans gene across species from WormBase (Inparanoid/EnsEMBL-Compara/OrthoFinder etc.), plus nematode orthologs and within-worm paralogs. Accepts a WBGene ID or gene name (auto-resolved). Example: WBGene00006818 (unc-86) returns cross-species orthologs like zebrafish pou4f4 and nematode orthologs like CSP40.g8217 (c_tribulationis).",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "WBGene identifier or gene name. Examples: 'WBGene00006818', 'unc-86'."
        }
      },
      "required": [
        "gene_id"
      ]
    },
    "fields": {
      "endpoint_type": "gene_orthologs"
    },
    "type": "WormBaseTool",
    "timeout": 30,
    "test_examples": [
      {
        "gene_id": "WBGene00006818"
      },
      {
        "gene_id": "unc-86"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "wormbase_id": {
