  {
    "name": "WormBase_get_interactions",
    "description": "Get physical and genetic interactions for a C. elegans gene from WormBase, split into physical and genetic lists with interactor names, IDs, interaction type, and citation. Accepts a WBGene ID or gene name. Example: WBGene00006818 (unc-86) has a physical interactor die-1 (WBGene00000995) and a genetic interactor ttx-3 (WBGene00006654).",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_id": {
          "type": "string",
          "description": "WBGene identifier or gene name. Examples: 'WBGene00006818', 'unc-86'."
        }
      },
      "required": [
        "gene_id"
