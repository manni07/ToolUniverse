                      },
                      "p_value": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "fdr": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "reactions_found": {
                        "type": [
                          "integer",
