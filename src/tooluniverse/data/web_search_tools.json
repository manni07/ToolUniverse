        "focus": "python_packages",
        "max_results": 3,
        "expected_output_type": "object",
        "description": "Search for requests Python package information"
      },
      {
        "query": "scikit-learn",
        "focus": "github_repos",
        "max_results": 3,
        "expected_output_type": "object",
        "description": "Search for scikit-learn GitHub repositories"
      }
    ],
    "metadata": {
      "tags": [
        "web-search",
        "api-documentation",
        "python-packages",
