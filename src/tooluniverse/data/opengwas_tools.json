                          "null"
                        ]
                      }
                    }
                  }
                },
                "n_instruments": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "n_mr_input": {
                  "type": [
                    "integer",
                    "null"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
