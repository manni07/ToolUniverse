[
  {
    "name": "RNAcentral_get_genome_locations",
    "type": "RNAcentralGenomeTool",
    "description": "Get the genomic coordinates of a non-coding RNA in a specific organism from RNAcentral. Provide an RNAcentral URS identifier (e.g. 'URS00003B7674' for let-7a) and an NCBI taxonomy id (e.g. 9606 for human). Returns each genomic mapping: chromosome, strand, start, end, UCSC/Ensembl assembly (GRCh38), and GCA accession. RNAcentral aggregates ncRNAs (miRNA, lncRNA, rRNA, snoRNA, tRNA, etc.) from 40+ member databases.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "description": "Fixed to 'genome_locations' for this tool.",
          "enum": [
            "genome_locations"
          ],
          "default": "genome_locations"
        },
        "urs_id": {
          "type": "string",
          "description": "RNAcentral URS identifier, e.g. 'URS00003B7674'. A trailing '_taxid' suffix is accepted and stripped."
        },
        "taxid": {
          "type": "integer",
          "description": "NCBI taxonomy id of the organism whose genome mapping is requested, e.g. 9606 (human), 10090 (mouse). Required."
        }
      },
      "required": [
        "urs_id",
        "taxid"
      ]
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Successful genome-location lookup.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success"
              ]
            },
            "source": {
              "type": "string"
            },
            "operation": {
              "type": "string"
            },
            "urs_id": {
              "type": "string"
            },
            "taxid": {
              "type": "integer"
            },
            "data": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "integer"
                },
                "locations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "chromosome": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "strand": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "start": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "end": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "identity": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "ucsc_chromosome": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "assembly_id": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "assembly_ucsc": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "gca_accession": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "common_name": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "taxid": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      }
                    }
                  }
                }
              },
              "required": [
                "count",
                "locations"
              ]
            }
          },
          "required": [
            "status",
            "urs_id",
            "taxid",
            "data"
          ]
        },
        {
          "type": "object",
          "description": "Error response.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "error": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "operation": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "operation": "genome_locations",
        "urs_id": "URS00003B7674",
        "taxid": 9606
      },
      {
        "operation": "genome_locations",
        "urs_id": "URS000075CC93",
        "taxid": 9606
      },
      {
        "operation": "genome_locations",
        "urs_id": "URS00003B7674",
        "taxid": 10090
      }
    ],
    "settings": {
      "base_url": "https://rnacentral.org/api/v1",
      "timeout": 30
    },
    "fields": {
      "operation": "genome_locations"
    }
  },
  {
    "name": "RNAcentral_get_sequence",
    "type": "RNAcentralGenomeTool",
    "description": "Get the nucleotide sequence (FASTA) of a non-coding RNA from RNAcentral. Provide an RNAcentral URS identifier (e.g. 'URS00003B7674'). Returns the FASTA header, the full RNA sequence string, and its length.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "description": "Fixed to 'sequence' for this tool.",
          "enum": [
            "sequence"
          ],
          "default": "sequence"
        },
        "urs_id": {
          "type": "string",
          "description": "RNAcentral URS identifier, e.g. 'URS00003B7674'. A trailing '_taxid' suffix is accepted and stripped."
        }
      },
      "required": [
        "urs_id"
      ]
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Successful sequence lookup.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "success"
              ]
            },
            "source": {
              "type": "string"
            },
            "operation": {
              "type": "string"
            },
            "urs_id": {
              "type": "string"
            },
            "data": {
              "type": "object",
              "properties": {
                "fasta_header": {
                  "type": "string"
                },
                "sequence": {
                  "type": "string"
                },
                "length": {
                  "type": "integer"
                }
              },
              "required": [
                "sequence",
                "length"
              ]
            }
          },
          "required": [
            "status",
            "urs_id",
            "data"
          ]
        },
        {
          "type": "object",
          "description": "Error response.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "error": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "operation": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "error"
          ]
        }
      ]
    },
    "test_examples": [
      {
        "operation": "sequence",
        "urs_id": "URS0000000001"
      },
      {
        "operation": "sequence",
        "urs_id": "URS00003B7674"
      }
    ],
    "settings": {
      "base_url": "https://rnacentral.org/api/v1",
      "timeout": 30
    },
    "fields": {
      "operation": "sequence"
    }
  }
]
