[
  {
    "name": "MetabolomicsWorkbench_get_study",
    "description": "Get metadata and information about a metabolomics study by its study ID. Returns study summary including title, subject species, analysis type, and metabolites.",
    "parameter": {
      "type": "object",
      "properties": {
        "study_id": {
          "type": "string",
          "description": "Metabolomics Workbench study ID (e.g., 'ST000001', 'ST000100')."
        },
        "output_item": {
          "type": "string",
          "description": "Type of information to return. Options: 'summary' (study overview), 'factors' (experimental factors), 'analysis' (analysis methods), 'metabolites' (metabolite list), 'data' (full data matrix).",
          "default": "summary",
          "enum": [
            "summary",
            "factors",
            "analysis",
            "metabolites",
            "data"
          ]
        }
      },
      "required": [
        "study_id"
      ]
    },
    "fields": {
      "context": "study",
      "output_format": "json"
    },
    "type": "MetabolomicsWorkbenchTool",
    "test_examples": [
      {
        "study_id": "ST000001"
      },
      {
        "study_id": "ST000100",
        "output_item": "metabolites"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": [
                "array",
                "string"
              ]
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  {
    "name": "MetabolomicsWorkbench_search_compound_by_name",
    "description": "Search for a metabolite/compound by its name using RefMet nomenclature. Returns standardized compound information including formula, exact mass, and classification. Use this for finding metabolites by common name.",
    "parameter": {
      "type": "object",
      "properties": {
        "input_value": {
          "type": "string",
          "description": "Compound/metabolite name to search (e.g., 'Glucose', 'Cholesterol', 'Palmitic acid'). Aliases: compound_name, name."
        },
        "compound_name": {
          "type": "string",
          "description": "Alias for input_value."
        },
        "output_item": {
          "type": "string",
          "description": "Type of output to return.",
          "default": "all"
        }
      },
      "required": []
    },
    "fields": {
      "context": "refmet",
      "input_item": "name"
    },
    "type": "MetabolomicsWorkbenchTool",
    "test_examples": [
      {
        "input_value": "glucose"
      },
      {
        "input_value": "cholesterol",
        "output_item": "all"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "pubchem_cid": {
                  "type": "string"
                },
                "inchi_key": {
                  "type": "string"
                },
                "exactmass": {
                  "type": "number"
                },
                "formula": {
                  "type": "string"
                },
                "super_class": {
                  "type": "string"
                },
                "main_class": {
                  "type": "string"
                },
                "sub_class": {
                  "type": "string"
                },
                "smiles": {
                  "type": "string"
                },
                "regno": {
                  "type": "string"
                },
                "refmet_id": {
                  "type": "string"
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
