            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
