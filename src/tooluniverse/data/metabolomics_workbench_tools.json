  {
    "name": "MetabolomicsWorkbench_search_by_mz",
    "description": "Search metabolites by m/z (mass-to-charge ratio) value from mass spectrometry data. Essential for metabolite identification from MS experiments.",
    "parameter": {
      "type": "object",
      "properties": {
        "mz_value": {
          "type": "number",
          "description": "The m/z value to search for (e.g., 180.0634 for glucose [M+H]+)."
        },
        "adduct": {
          "type": "string",
          "description": "Adduct type. Common values: 'M+H' (protonated), 'M-H' (deprotonated), 'M+Na' (sodiated), 'M+K' (potassiated).",
          "default": "M+H"
        },
        "tolerance": {
          "type": "number",
          "description": "Mass tolerance in Daltons for the search.",
          "default": 0.1
        },
        "database": {
          "type": "string",
          "description": "Database to search: 'MB' (Metabolomics Workbench, default), 'LIPIDS', or 'REFMET'.",
          "enum": [
            "MB",
            "LIPIDS",
            "REFMET"
          ],
          "default": "MB"
        }
      },
      "required": [
        "mz_value"
      ]
    },
    "fields": {
      "context": "moverz"
    },
    "type": "MetabolomicsWorkbenchTool",
    "test_examples": [
      {
        "mz_value": 180.0634,
        "adduct": "M+H",
        "tolerance": 0.1
      },
      {
        "mz_value": 146.0579,
        "adduct": "M-H",
        "tolerance": 0.05
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
