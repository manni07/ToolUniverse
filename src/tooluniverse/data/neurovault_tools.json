  {
    "name": "NeuroVault_list_collection_images",
    "description": "List all statistical map images in a specific NeuroVault collection. Returns image metadata including name, map type (T map, Z map, F map, etc.), cognitive paradigm/contrast annotations, and file download URLs. Use this to explore what brain maps are available in a study collection before downloading. Example: collection 457 (Human Connectome Project) has 48 images covering emotion, gambling, language, motor, relational, social, and working memory tasks.",
    "parameter": {
      "type": "object",
      "properties": {
        "collection_id": {
          "type": "integer",
          "description": "NeuroVault collection ID. Example: 457 (Human Connectome Project)"
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of images to return (default 10, max 100)"
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of images to skip for pagination (default 0)"
        }
      },
      "required": [
        "collection_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/collections/{collection_id}/images/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "collection_id": 457,
        "limit": 5
      },
      {
        "collection_id": 1952,
        "limit": 3
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Paginated list of images in the collection",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Total number of images"
            },
            "next": {
              "type": [
                "string",
                "null"
              ]
            },
            "previous": {
              "type": [
                "string",
                "null"
              ]
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Image ID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Image name"
                  },
                  "map_type": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Statistical map type: T map, Z map, F map, etc."
                  },
                  "file": {
                    "type": "string",
                    "description": "URL to download the NIfTI image file"
                  },
                  "collection_id": {
                    "type": "integer"
                  },
                  "cognitive_paradigm_cogatlas": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Cognitive Atlas paradigm label"
                  },
                  "cognitive_paradigm_cogatlas_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "cognitive_contrast_cogatlas": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Cognitive Atlas contrast label"
                  },
                  "analysis_level": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Analysis level: group or individual"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "NeuroVault_get_image",
    "description": "Get detailed metadata for a specific brain statistical map image in NeuroVault by image ID. Returns comprehensive information including map type (T/Z/F map), cognitive paradigm and contrast annotations from Cognitive Atlas, analysis level, modality, and file download URL (NIfTI format). Use image IDs from NeuroVault_list_collection_images. Example: image 3128 is a Z map of 'emotion processing fMRI task paradigm' showing FACES minus SHAPES contrast from the Human Connectome Project.",
    "parameter": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "integer",
          "description": "NeuroVault image ID. Examples: 3128 (HCP emotion task Z map), 946 (pain T map)"
        }
      },
      "required": [
        "image_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/images/{image_id}/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "image_id": 3128
      },
      {
        "image_id": 946
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Detailed image metadata",
          "properties": {
            "id": {
              "type": "integer",
              "description": "Image ID"
            },
            "name": {
              "type": "string",
              "description": "Image name/description"
            },
            "file": {
              "type": "string",
              "description": "URL to download the NIfTI image file"
            },
            "collection_id": {
              "type": "integer",
              "description": "Parent collection ID"
            },
            "map_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Statistical map type: T map, Z map, F map, univariate-beta map, ROI/mask, parcellation, etc."
            },
            "cognitive_paradigm_cogatlas": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas paradigm label (e.g., 'emotion processing fMRI task paradigm')"
            },
            "cognitive_paradigm_cogatlas_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas paradigm ID"
            },
            "cognitive_contrast_cogatlas": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas contrast label"
            },
            "cognitive_contrast_cogatlas_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "analysis_level": {
              "type": [
                "string",
                "null"
              ],
              "description": "Analysis level: group or individual"
            },
            "modality": {
              "type": [
                "string",
                "null"
              ],
              "description": "Imaging modality (fMRI-BOLD, PET, etc.)"
            },
            "image_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Image type (statistic_map, atlas, etc.)"
            },
            "statistic_parameters": {
              "type": [
                "number",
                "null"
              ]
            },
            "smoothness_fwhm": {
              "type": [
                "number",
                "null"
              ],
              "description": "Smoothing kernel FWHM in mm"
            },
            "brain_coverage": {
              "type": [
                "number",
                "null"
              ]
            },
            "not_mni": {
              "type": "boolean",
              "description": "Whether image is NOT in MNI space"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "NeuroVault_list_atlases",
    "description": "List labeled anatomical brain atlas maps (parcellation/label images) hosted on NeuroVault. Each atlas is a label image (NIfTI) paired with a label-description file (XML/text) that names each parcel/region. Returns metadata including name, the .nii.gz file URL, the label_description_file URL, and the parent collection. Use limit and offset for pagination. NeuroVault hosts 18 atlases. Example: returns atlases like 'Thalamus maxprob thr25 2mm'.",
    "parameter": {
      "type": "object",
      "properties": {
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of atlases to return per page (default 10, max 100). Example: 10"
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of atlases to skip for pagination (default 0)."
        },
        "format": {
          "type": [
            "string",
            "null"
          ],
          "description": "Response format. Must be 'json'. Default: 'json'."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/atlases/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "limit": 5
      },
      {
        "limit": 3,
        "offset": 2
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Paginated list of NeuroVault atlas maps",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Total number of atlases available"
            },
            "next": {
              "type": [
                "string",
                "null"
              ]
            },
            "previous": {
              "type": [
                "string",
                "null"
              ]
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Atlas image ID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Atlas name"
                  },
                  "file": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "URL to the label image NIfTI file (.nii.gz)"
                  },
                  "label_description_file": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "URL to the label-description file (XML/text) naming each parcel"
                  },
                  "collection": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "URL of the parent collection"
                  },
                  "collection_id": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "NeuroVault_get_atlas",
    "description": "Get detailed metadata for a single labeled anatomical brain atlas map in NeuroVault by its atlas ID. Returns the atlas name, the label image NIfTI file URL (.nii.gz), the label_description_file URL (XML/text naming each parcel/region), the parent collection, and acquisition metadata. Get an atlas ID from NeuroVault_list_atlases. Example: id=14228 returns 'Thalamus maxprob thr25 2mm', file Thalamus-maxprob-thr25-2mm.nii.gz, label_description_file Thalamus-maxprob-thr25-2mm.xml, collection 1056.",
    "parameter": {
      "type": "object",
      "properties": {
        "atlas_id": {
          "type": "integer",
          "description": "NeuroVault atlas image ID. Get one from NeuroVault_list_atlases. Example: 14228 (Thalamus maxprob thr25 2mm)."
        }
      },
      "required": [
        "atlas_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/atlases/{atlas_id}/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "atlas_id": 14228
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Detailed atlas metadata",
          "properties": {
            "id": {
              "type": "integer",
              "description": "Atlas image ID"
            },
            "name": {
              "type": "string",
              "description": "Atlas name"
            },
            "file": {
              "type": [
                "string",
                "null"
              ],
              "description": "URL to the label image NIfTI file (.nii.gz)"
            },
            "label_description_file": {
              "type": [
                "string",
                "null"
              ],
              "description": "URL to the label-description file (XML/text) naming each parcel/region"
            },
            "collection": {
              "type": [
                "string",
                "null"
              ],
              "description": "URL of the parent collection"
            },
            "collection_id": {
              "type": [
                "integer",
                "null"
              ]
            },
            "description": {
              "type": [
                "string",
                "null"
              ]
            },
            "target_template_image": {
              "type": [
                "string",
                "null"
              ]
            },
            "add_date": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
