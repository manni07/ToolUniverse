      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query: gene symbol, name fragment, or MGI ID (e.g., 'Wdr7', 'WD repeat', 'MGI:2442934')"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum results (default: 20)",
          "default": 20,
          "minimum": 1,
          "maximum": 100
