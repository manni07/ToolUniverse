[
  {
    "name": "IMPC_get_gene_summary",
    "description": "Get mouse gene summary from IMPC including phenotyping status, viability, ortholog info, and MP/HP term annotations. Query by human gene symbol or MGI ID. No API key needed. Essential for safety/liability triangulation via mouse KO phenotypes.",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_symbol": {
          "type": "string",
          "description": "Mouse gene symbol (e.g., 'Trp53', 'Brca1', 'Wdr7'). Case-sensitive. Use mouse symbol, not human."
        },
        "mgi_id": {
          "type": "string",
          "description": "MGI accession ID (e.g., 'MGI:98834'). Use if gene symbol is ambiguous."
        }
      }
    },
    "fields": {
      "operation": "get_gene_summary"
    },
    "type": "IMPCTool",
    "test_examples": [
      {
        "gene_symbol": "Trp53"
      },
      {
        "mgi_id": "MGI:98834"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "mgi_id": {
                  "type": "string"
                },
                "symbol": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "synonyms": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "human_ortholog": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "marker_type": {
                  "type": "string"
                },
                "phenotype_status": {
                  "type": "null"
                },
                "production_status": {
                  "type": "null"
                },
                "phenotyping_centre": {
                  "type": "null"
                },
                "production_centre": {
                  "type": "null"
                },
                "has_phenotype_data": {
                  "type": "boolean"
                },
                "mp_terms": {
                  "type": "array"
                },
                "mp_ids": {
                  "type": "array"
                },
                "top_level_mp_terms": {
                  "type": "array"
                },
                "hp_terms": {
                  "type": "array"
                },
                "disease_associations": {
                  "type": "array"
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    },
    "label": [
      "IMPC",
      "MGI",
      "Mouse",
      "Phenotype",
      "Knockout"
    ],
    "metadata": {
      "tags": [
        "mouse_model",
        "knockout",
        "phenotype",
        "safety",
        "target_validation"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
