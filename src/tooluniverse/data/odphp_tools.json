  {
    "name": "odphp_topicsearch",
    "description": "Find specific health topics and get their full content. Use when the user mentions a keyword (e.g., \u201cfolic acid\u201d, \u201cblood pressure\u201d) or when you already have topic/category IDs from `odphp_itemlist`. Returns detailed topic pages (Title, Sections, RelatedItems) and an AccessibleVersion link. Next: to quote or summarize the actual page text, pass the AccessibleVersion (or RelatedItems URLs) to `odphp_outlink_fetch`.",
    "type": "ODPHPTopicSearch",
    "parameter": {
      "type": "object",
      "properties": {
        "lang": {
          "type": "string",
          "description": "Language code (en or es)"
        },
        "topicId": {
          "type": "string",
          "description": "Comma-separated topic IDs"
        },
        "categoryId": {
          "type": "string",
          "description": "Comma-separated category IDs"
        },
        "keyword": {
          "type": "string",
          "description": "Keyword search for topics"
        },
        "strip_html": {
          "type": "boolean",
          "description": "If true, also return PlainSections[] with HTML removed for each topic"
        }
      },
      "required": [
        "lang",
        "topicId",
        "categoryId",
        "keyword",
        "strip_html"
      ]
    },
    "fields": {
      "endpoint": "/topicsearch.json",
      "return_format": "JSON"
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "Error": {
                  "type": "string"
                },
                "Total": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "Query": {
                  "type": "object",
                  "properties": {
                    "ApiVersion": {
                      "type": "string"
                    },
                    "ApiType": {
                      "type": "string"
                    },
                    "TopicId": {
                      "type": "string"
                    },
                    "CategoryId": {
                      "type": "null"
                    },
                    "Keyword": {
                      "type": "string"
                    },
                    "Age": {
                      "type": "null"
                    },
                    "Sex": {
                      "type": "null"
                    },
                    "Pregnant": {
                      "type": "null"
                    },
                    "Lang": {
                      "type": "string"
                    },
                    "Type": {
                      "type": "null"
                    },
                    "ReturnType": {
                      "type": "string"
                    },
                    "Callback": {
                      "type": "null"
                    },
                    "APiType": {
                      "type": "string"
                    }
                  }
                },
                "Language": {
                  "type": "string"
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    },
    "test_examples": [
      {
        "lang": "en",
        "topicId": "30544",
        "categoryId": "15",
        "keyword": "diabetes",
        "strip_html": true
      }
    ]
  },
  {
    "name": "odphp_outlink_fetch",
    "description": "This tool retrieves readable text from ODPHP article links and information sources. This is helpful after using the `odphp_myhealthfinder` or `odphp_topicsearch` tools or when the user wants to simply dive deeper into ODPHP data.",
    "type": "ODPHPOutlinkFetch",
    "parameter": {
      "type": "object",
      "properties": {
        "urls": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "1\u20133 absolute URLs from AccessibleVersion or RelatedItems.Url"
        },
        "max_chars": {
          "type": "integer",
          "description": "Optional hard cap on extracted text length (e.g., 5000)"
        },
        "return_html": {
          "type": "boolean",
          "description": "If true, also return minimally cleaned HTML"
        }
      },
      "required": [
        "urls",
        "max_chars",
        "return_html"
      ]
    },
    "fields": {
      "endpoint": "/outlink",
      "return_format": "JSON"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "status": {
                "type": [
                  "integer",
                  "number"
                ]
              },
              "content_type": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "urls": [
          "https://health.gov/myhealthfinder/api/v3/topicsearch.json?topicId=30606"
        ],
        "max_chars": 2000,
        "return_html": false
      },
      {
        "urls": [
          "https://health.gov/myhealthfinder/api/v3/topicsearch.json?topicId=30606"
        ],
        "max_chars": 5000,
        "return_html": false
      }
    ]
  }
]
