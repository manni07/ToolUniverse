[
  {
    "type": "ReMapRESTTool",
    "name": "ReMap_get_transcription_factor_binding",
    "description": "Get transcription factor binding sites from ReMap database for specific genes and cell types",
    "parameter": {
      "type": "object",
      "properties": {
        "gene_name": {
          "type": "string",
          "description": "Gene symbol (e.g., BRCA1, TP53, MYC)"
        },
        "cell_type": {
          "type": "string",
          "description": "Cell type (e.g., HepG2, K562, MCF-7)",
          "default": "HepG2"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results to return",
          "default": 10,
          "minimum": 1,
          "maximum": 50
        }
      },
      "required": [
        "gene_name"
      ]
    },
    "fields": {
      "endpoint": "https://www.encodeproject.org/search/?type=Experiment&assay_title=TF+ChIP-seq&target.label={gene_name}&biosample_ontology.term_name={cell_type}&format=json&limit={limit}",
      "return_format": "JSON"
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": ["experiments", "count", "gene_name", "cell_type"],
          "properties": {
            "experiments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "accession": {"type": "string"},
                  "assay_title": {"type": "string"},
                  "target": {"type": ["object", "null"]},
                  "biosample_ontology": {"type": ["object", "null"]},
                  "description": {"type": ["string", "null"]},
                  "status": {"type": ["string", "null"]}
                }
              }
            },
            "gene_name": {"type": "string"},
            "cell_type": {"type": "string"},
            "count": {"type": "integer"},
            "url": {"type": "string"},
            "note": {"type": "string"}
          }
        },
        {
          "type": "object",
          "required": ["error"],
          "properties": {
            "error": {"type": "string"}
          }
        }
      ]
    },
    "test_examples": [
      {
        "gene_name": "BRCA1",
        "cell_type": "HepG2",
        "limit": 5
      },
      {
        "gene_name": "TP53",
        "cell_type": "HepG2",
        "limit": 3
      },
      {
        "gene_name": "MYC",
        "cell_type": "MCF-7",
        "limit": 5
      }
    ]
  },
  {
    "type": "ReMapRESTTool",
    "name": "ReMap_get_peaks_in_region",
    "description": "Retrieve all ChIP-seq transcriptional-regulator (TR) binding peaks from the ReMap catalog that overlap a genomic interval. Give a region (chrom:start-end) and get back every overlapping peak with its genomic coordinates plus the bound TF, the cell line/tissue (biotype), the source experiment accession (GEO/ENCODE), and any treatments. This is the defining ReMap capability (region in -> all overlapping TR peaks out). Use for: enumerating which transcription factors bind a locus, finding regulatory occupancy of a promoter/enhancer interval, listing TFs near a variant. Keep regions modest (<=1 Mb) - large intervals can return tens of thousands of peaks.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["get_peaks_in_region"],
          "default": "get_peaks_in_region",
          "description": "Operation selector. Must be 'get_peaks_in_region'."
        },
        "region": {
          "type": "string",
          "description": "Genomic interval as chrom:start-end (e.g. 'chr1:1000000-1100000'). Commas in coordinates are tolerated."
        },
        "assembly": {
          "type": "string",
          "description": "Genome assembly.",
          "enum": ["hg38", "hg19", "mm10", "mm39"],
          "default": "hg38"
        },
        "version": {
          "type": "string",
          "description": "ReMap catalog release year.",
          "enum": ["2022", "2020", "2018"],
          "default": "2022"
        },
        "datatype": {
          "type": "string",
          "description": "Peak datatype: 'all' for the non-redundant merged peak set across all TFs.",
          "default": "all"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Optional cap on the number of peaks returned (peak_count still reports the true total). Omit to return all overlapping peaks.",
          "minimum": 1
        }
      },
      "required": ["region"]
    },
    "fields": {
      "operation": "get_peaks_in_region",
      "endpoint": "https://remap-rest.univ-amu.fr/api/V1/get_peaks/{version}/{assembly}/{datatype}/{region}?format=json",
      "return_format": "JSON"
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": ["region", "peak_count", "peaks"],
          "properties": {
            "region": {"type": "string"},
            "assembly": {"type": "string"},
            "version": {"type": "string"},
            "datatype": {"type": "string"},
            "size": {"type": ["integer", "string", "null"]},
            "peak_count": {"type": "integer"},
            "returned_count": {"type": "integer"},
            "unique_tf_count": {"type": "integer"},
            "unique_tfs": {"type": "array", "items": {"type": "string"}},
            "peaks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "chrom": {"type": ["string", "null"]},
                  "chromStart": {"type": ["string", "integer", "null"]},
                  "chromEnd": {"type": ["string", "integer", "null"]},
                  "experiment": {"type": ["string", "null"]},
                  "tf": {"type": ["string", "null"]},
                  "biotype": {"type": ["string", "null"]},
                  "treatments": {"type": "array", "items": {"type": "string"}}
                }
              }
            },
            "url": {"type": "string"}
          }
        },
        {
          "type": "object",
          "required": ["error"],
          "properties": {"error": {"type": "string"}}
        }
      ]
    },
    "test_examples": [
      {
        "operation": "get_peaks_in_region",
        "region": "chr1:1000000-1010000",
        "assembly": "hg38",
        "version": "2022",
        "limit": 25
      }
    ]
  }
]
