      "type": "object",
      "properties": {
        "complex_id": {
          "type": "string",
          "description": "Complex Portal accession ID (e.g., 'CPX-1', 'CPX-6512')"
        }
      },
      "required": [
        "complex_id"
      ]
    },
    "fields": {
      "operation": "get_complex"
    },
    "type": "ComplexPortalTool",
    "test_examples": [
