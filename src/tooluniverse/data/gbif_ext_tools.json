[
  {
    "name": "GBIF_get_species",
    "description": "Get detailed species information from the Global Biodiversity Information Facility (GBIF) by its taxon key. Returns the full taxonomic record including scientific name, authorship, rank, full classification (kingdom through species), taxonomic status, basionym, vernacular name, and number of descendant taxa. Use GBIF_search_species first to find taxon keys. Example: key 2435099 returns Puma concolor (puma) with full classification from Animalia to Puma concolor.",
    "parameter": {
      "type": "object",
      "properties": {
        "speciesKey": {
          "type": "integer",
          "description": "GBIF species/taxon key. Examples: 2435099 (Puma concolor / puma), 2878688 (Quercus robur / English oak), 5219404 (Canis lupus / wolf), 2480528 (Homo sapiens), 2495662 (Aquila chrysaetos / golden eagle). Use GBIF_search_species to find keys."
        }
      },
      "required": [
        "speciesKey"
      ]
    },
    "fields": {
      "endpoint": "https://api.gbif.org/v1/species/{speciesKey}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "speciesKey": 2435099
      },
      {
        "speciesKey": 2878688
      },
      {
        "speciesKey": 5219404
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GBIF species record",
          "properties": {
            "key": {
              "type": "integer",
              "description": "GBIF taxon key"
            },
            "scientificName": {
              "type": "string",
              "description": "Full scientific name with authority"
            },
            "canonicalName": {
              "type": [
                "string",
                "null"
              ],
              "description": "Scientific name without authority"
            },
            "vernacularName": {
              "type": [
                "string",
                "null"
              ],
              "description": "Common name"
            },
            "authorship": {
              "type": [
                "string",
                "null"
              ],
              "description": "Taxonomic authority"
            },
            "rank": {
              "type": "string",
              "description": "Taxonomic rank (KINGDOM, PHYLUM, CLASS, ORDER, FAMILY, GENUS, SPECIES)"
            },
            "taxonomicStatus": {
              "type": "string",
              "description": "Status: ACCEPTED, SYNONYM, DOUBTFUL, etc."
            },
            "kingdom": {
              "type": [
                "string",
                "null"
              ],
              "description": "Kingdom name"
            },
            "phylum": {
              "type": [
                "string",
                "null"
              ],
              "description": "Phylum name"
            },
            "class": {
              "type": [
                "string",
                "null"
              ],
              "description": "Class name"
            },
            "order": {
              "type": [
                "string",
                "null"
              ],
              "description": "Order name"
            },
            "family": {
              "type": [
                "string",
                "null"
              ],
              "description": "Family name"
            },
            "genus": {
              "type": [
                "string",
                "null"
              ],
              "description": "Genus name"
            },
            "species": {
              "type": [
                "string",
                "null"
              ],
              "description": "Species binomial"
            },
            "kingdomKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Kingdom taxon key"
            },
            "phylumKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Phylum taxon key"
            },
            "classKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Class taxon key"
            },
            "orderKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Order taxon key"
            },
            "familyKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Family taxon key"
            },
            "genusKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Genus taxon key"
            },
            "speciesKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Species taxon key"
            },
            "parent": {
              "type": [
                "string",
                "null"
              ],
              "description": "Parent taxon name"
            },
            "parentKey": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Parent taxon key"
            },
            "basionym": {
              "type": [
                "string",
                "null"
              ],
              "description": "Original name (basionym)"
            },
            "numDescendants": {
              "type": "integer",
              "description": "Number of descendant taxa"
            },
            "origin": {
              "type": [
                "string",
                "null"
              ],
              "description": "Data origin (SOURCE, DENORMED_CLASSIFICATION)"
            },
            "publishedIn": {
              "type": [
                "string",
                "null"
              ],
              "description": "Publication reference"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "GBIF_suggest_species",
    "description": "Autocomplete species names using the GBIF species suggestion endpoint. Returns quick matches as you type, with basic taxonomic info (key, name, rank, classification). Faster and lighter than full search -- designed for type-ahead interfaces and quick name resolution. Returns up to 20 suggestions. Example: 'Quer' matches Quercus (oaks), Quercus robur (English oak), etc.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Partial or full species/taxon name to autocomplete. Examples: 'Homo sap', 'Quercus', 'Pan trog', 'Escherichia', 'Drosoph'."
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of suggestions to return (1-20, default 10)."
        }
      },
      "required": [
        "q"
      ]
    },
    "fields": {
      "endpoint": "https://api.gbif.org/v1/species/suggest"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "q": "Quercus robur"
      },
      {
        "q": "Homo sap",
        "limit": 5
      },
      {
        "q": "Drosophila melano"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of matching species suggestions",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "integer",
                "description": "GBIF taxon key"
              },
              "scientificName": {
                "type": "string",
                "description": "Full scientific name with authority"
              },
              "canonicalName": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Scientific name without authority"
              },
              "rank": {
                "type": "string",
                "description": "Taxonomic rank"
              },
              "status": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "ACCEPTED or SYNONYM"
              },
              "kingdom": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Kingdom"
              },
              "phylum": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Phylum"
              },
              "class": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Class"
              },
              "order": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Order"
              },
              "family": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Family"
              },
              "genus": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Genus"
              },
              "species": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Species binomial"
              },
              "speciesKey": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Species taxon key"
              },
              "synonym": {
                "type": "boolean",
                "description": "Whether this name is a synonym"
              },
              "higherClassificationMap": {
                "type": "object",
                "description": "Map of taxon keys to names in classification hierarchy"
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "GBIF_match_name",
    "description": "Resolve a free-text scientific name to the single best-matching GBIF Backbone taxon. Unlike GBIF_search_species / GBIF_suggest_species (which return ranked candidate lists), this returns the one authoritative match with a stable usageKey (taxonKey), matchType (EXACT/FUZZY/HIGHERRANK/NONE), a confidence score (0-100), taxonomic status, and the full key-bearing lineage (kingdomKey..speciesKey). This is the GBIF-recommended way to map names to stable taxon keys for downstream occurrence queries. Example: name='Puma concolor' -> usageKey 2435099, matchType EXACT, confidence 99. No API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Scientific name to match, e.g. 'Puma concolor', 'Quercus robur', 'Homo sapiens'."
        },
        "kingdom": {"type": ["string", "null"], "description": "Optional kingdom to disambiguate homonyms, e.g. 'Animalia', 'Plantae'."},
        "rank": {"type": ["string", "null"], "description": "Optional rank hint, e.g. 'SPECIES', 'GENUS'."},
        "strict": {"type": ["boolean", "null"], "description": "If true, only return exact matches (no fuzzy matching)."},
        "verbose": {"type": ["boolean", "null"], "description": "If true, include alternative matches in the response."}
      },
      "required": ["name"]
    },
    "fields": {
      "endpoint": "https://api.gbif.org/v1/species/match"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "Puma concolor"},
      {"name": "Quercus robur"},
      {"name": "Gadus morhua"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GBIF single best name match",
          "properties": {
            "status": {"type": "string"},
            "data": {
              "type": "object",
              "properties": {
                "usageKey": {"type": ["integer", "null"], "description": "Stable GBIF taxon key for the matched name"},
                "scientificName": {"type": ["string", "null"]},
                "canonicalName": {"type": ["string", "null"]},
                "rank": {"type": ["string", "null"]},
                "status": {"type": ["string", "null"], "description": "ACCEPTED, SYNONYM, DOUBTFUL"},
                "confidence": {"type": ["integer", "null"], "description": "Match confidence score 0-100"},
                "matchType": {"type": ["string", "null"], "description": "EXACT, FUZZY, HIGHERRANK, or NONE"},
                "kingdom": {"type": ["string", "null"]},
                "phylum": {"type": ["string", "null"]},
                "class": {"type": ["string", "null"]},
                "order": {"type": ["string", "null"]},
                "family": {"type": ["string", "null"]},
                "genus": {"type": ["string", "null"]},
                "species": {"type": ["string", "null"]},
                "kingdomKey": {"type": ["integer", "null"]},
                "phylumKey": {"type": ["integer", "null"]},
                "classKey": {"type": ["integer", "null"]},
                "orderKey": {"type": ["integer", "null"]},
                "familyKey": {"type": ["integer", "null"]},
                "genusKey": {"type": ["integer", "null"]},
                "speciesKey": {"type": ["integer", "null"]}
              }
            },
            "url": {"type": "string"}
          },
          "required": ["status", "data"]
        },
        {
          "type": "object",
          "properties": {"status": {"type": "string"}, "error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "GBIF_occurrence_stats",
    "description": "Get GBIF occurrence statistics for a taxonKey: the total occurrence count plus faceted breakdowns (occurrences per country, year, basisOfRecord, or institutionCode). Unlike GBIF_search_occurrences (which returns raw records with no aggregation), this uses limit=0 with a facet parameter so it returns quantitative summaries over the whole matching set. Get a taxonKey from GBIF_match_name or GBIF_search_species. Example: taxonKey=2435099 (Puma concolor), facet=country -> count 29340 with per-country counts (US 11380, AR 3368, ...). No API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "taxonKey": {
          "type": "integer",
          "description": "GBIF taxon key, e.g. 2435099 (Puma concolor). Obtain from GBIF_match_name or GBIF_search_species."
        },
        "facet": {
          "type": ["string", "null"],
          "description": "Field to break occurrence counts down by, e.g. 'country', 'year', 'basisOfRecord', or 'institutionCode'. Default 'country'.",
          "default": "country"
        },
        "facetLimit": {
          "type": ["integer", "null"],
          "description": "Number of top facet values to return (default 10).",
          "default": 10
        },
        "country": {"type": ["string", "null"], "description": "Optional ISO 3166-1 alpha-2 country code filter, e.g. 'US'."}
      },
      "required": ["taxonKey"]
    },
    "fields": {
      "endpoint": "https://api.gbif.org/v1/occurrence/search",
      "params": {"limit": 0}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"taxonKey": 2435099, "facet": "country", "facetLimit": 5},
      {"taxonKey": 2435099, "facet": "year", "facetLimit": 5},
      {"taxonKey": 2878688, "facet": "country", "facetLimit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "GBIF occurrence count and facets",
          "properties": {
            "status": {"type": "string"},
            "data": {
              "type": "object",
              "properties": {
                "count": {"type": ["integer", "null"], "description": "Total occurrence count for the taxon/filters"},
                "limit": {"type": "integer"},
                "facets": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "field": {"type": "string"},
                      "counts": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {"type": "string"},
                            "count": {"type": "integer"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "url": {"type": "string"}
          },
          "required": ["status", "data"]
        },
        {
          "type": "object",
          "properties": {"status": {"type": "string"}, "error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
