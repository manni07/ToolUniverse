  {
    "type": "OLSTool",
    "name": "ols_find_similar_terms",
    "description": "Find similar terms using LLM-based similarity",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "find_similar_terms",
          "description": "The operation to perform (find_similar_terms)"
        },
        "term_iri": {
          "type": "string",
          "description": "The IRI of the term to find similar terms for"
        },
        "ontology": {
          "type": "string",
          "description": "The ontology ID"
        },
        "size": {
          "type": "integer",
          "description": "Number of similar terms to return (default: 10)",
          "default": 10
        },
        "term_id": {
          "type": "string",
          "description": "Alias for term_iri. Short-form ontology ID (e.g., GO:0008150) or full IRI."
        }
      },
      "required": [
        "ontology"
      ]
    },
    "examples": [
      {
        "description": "Find similar terms using LLM",
        "arguments": {
          "operation": "find_similar_terms",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo",
          "size": 5
        }
      }
    ],
    "tags": [
      "ontology",
      "similarity",
      "llm",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "size": 10
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "term_iri": {
          "type": "string"
        },
        "source_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "ontology": {
          "type": [
            "string",
            "null"
          ]
        },
        "similar_terms": {
          "type": "array",
          "items": {
            "type": "object"
          }
