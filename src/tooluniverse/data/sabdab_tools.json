[
  {
    "name": "SAbDab_search_structures",
    "description": "Search SAbDab structural antibody database. Returns a direct browse URL to matching antibody structures \u2014 SAbDab's search endpoint does not expose a JSON API, so use SAbDab_get_structure with a known PDB ID for structured data. Tip: retrieve the full SAbDab summary TSV from https://opig.stats.ox.ac.uk/webapps/sabdab-sabpred/sabdab/summary/?all=true for bulk filtering.",
    "type": "SAbDabTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_structures"
        },
        "query": {
          "type": "string",
          "description": "Search query - antigen name, species, or keywords (e.g., 'HER2', 'anti-CD20')"
        },
        "antigen": {
          "type": "string",
          "description": "Alias for query. Antigen name to search (e.g., 'EGFR', 'HER2')."
        },
        "limit": {
          "type": "integer",
          "description": "Maximum results (default: 50)",
          "default": 50
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "test_examples": [
      {
        "query": "anti-CD20"
      }
    ]
  },
  {
    "name": "SAbDab_get_structure",
    "description": "Get antibody structure details from SAbDab by PDB ID. Returns CDR annotations, chain information, and antigen binding data. Useful for structural analysis of antibody-antigen complexes.",
    "type": "SAbDabTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_structure"
        },
        "pdb_id": {
          "type": "string",
          "description": "4-character PDB ID (e.g., 1IGT, 6W41). Alias: pdb_code."
        },
        "pdb_code": {
          "type": "string",
          "description": "Alias for pdb_id. 4-character PDB ID (e.g., 1IGT, 6W41)."
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "test_examples": [
      {
        "pdb_id": "1AHW"
      }
    ]
  },
  {
    "name": "SAbDab_get_structure_summary",
    "description": "Get per-structure curated antibody annotations from SAbDab for a PDB ID. Returns the SAbDab summary TSV row(s): antigen name/type/species, heavy/light chain species and IMGT V-gene subclass, resolution, experimental method, R-free / R-factor, scFv and engineered flags, and (when curated) binding affinity Kd, delta_G, affinity method, temperature and PMID. Use for antibody-antigen complex characterization. Pass a 4-character PDB ID (e.g., 7d6i, 3hfm). No authentication required.",
    "type": "SAbDabTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_structure_summary"
        },
        "pdb_id": {
          "type": "string",
          "description": "4-character PDB ID of an antibody structure (e.g., '7d6i', '3hfm'). Aliases: pdb_code, pdb."
        },
        "pdb_code": {
          "type": "string",
          "description": "Alias for pdb_id."
        },
        "pdb": {
          "type": "string",
          "description": "Alias for pdb_id."
        }
      },
      "required": []
    },
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "pdb_id": {
                  "type": "string"
                },
                "antigen_name": {
                  "type": ["string", "null"]
                },
                "antigen_species": {
                  "type": ["string", "null"]
                },
                "heavy_species": {
                  "type": ["string", "null"]
                },
                "light_species": {
                  "type": ["string", "null"]
                },
                "resolution": {
                  "type": ["number", "string", "null"]
                },
                "method": {
                  "type": ["string", "null"]
                },
                "r_free": {
                  "type": ["number", "string", "null"]
                },
                "r_factor": {
                  "type": ["number", "string", "null"]
                },
                "heavy_subclass": {
                  "type": ["string", "null"]
                },
                "light_subclass": {
                  "type": ["string", "null"]
                },
                "scfv": {
                  "type": ["boolean", "null"]
                },
                "engineered": {
                  "type": ["boolean", "null"]
                },
                "affinity": {
                  "type": ["number", "string", "null"]
                },
                "delta_g": {
                  "type": ["number", "string", "null"]
                },
                "pmid": {
                  "type": ["integer", "string", "null"]
                },
                "chains": {
                  "type": "array"
                },
                "count": {
                  "type": "integer"
                }
              },
              "required": ["pdb_id", "chains", "count"]
            },
            "metadata": {
              "type": "object"
            }
          },
          "required": ["status", "data"]
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          },
          "required": ["status", "error"]
        }
      ]
    },
    "test_examples": [
      {
        "pdb_id": "7d6i"
      },
      {
        "pdb_id": "3hfm"
      }
    ]
  },
  {
    "name": "SAbDab_get_summary",
    "description": "Get SAbDab database summary and statistics. Returns information about database content, features, and access URLs. Good starting point for exploring antibody structural data.",
    "type": "SAbDabTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_summary"
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "test_examples": [
      {}
    ]
  }
]
