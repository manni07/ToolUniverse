  {
    "name": "CPIC_get_gene_drug_pairs",
    "description": "Get all gene-drug pairs for a pharmacogene from CPIC. Shows which drugs are affected by variants in a specific gene, with CPIC evidence level and PharmGKB clinical annotation level. Evidence levels: A (strongest) to D (weakest). Useful for understanding the clinical significance of a pharmacogene. Provide gene as 'genesymbol', 'gene_symbol', or 'gene'.",
    "parameter": {
      "type": "object",
      "properties": {
        "genesymbol": {
          "type": [
            "string",
            "null"
          ],
          "description": "Gene symbol (e.g., 'CYP2D6', 'CYP2C19', 'SLCO1B1', 'TPMT', 'DPYD', 'VKORC1')"
        },
        "gene_symbol": {
          "type": [
            "string",
            "null"
          ],
          "description": "Alias for genesymbol (e.g., 'CYP2D6')"
        },
        "gene": {
          "type": [
            "string",
            "null"
          ],
          "description": "Alias for genesymbol (e.g., 'CYP2D6')"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.cpicpgx.org/v1/pair?genesymbol=eq.{genesymbol}",
      "params": {
        "select": "*,drug(name)"
      }
    },
    "type": "CPICSearchPairsTool",
    "test_examples": [
      {
        "genesymbol": "CYP2D6"
      },
      {
        "genesymbol": "DPYD"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
