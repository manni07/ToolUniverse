                  "pairid": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "genesymbol": {
                    "type": "string"
                  },
                  "drugid": {
                    "type": "string"
                  },
                  "guidelineid": {
                    "type": [
                      "integer",
                      "null",
                      "number"
                    ]
                  },
                  "usedforrecommendation": {
                    "type": "boolean"
                  },
                  "version": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "cpiclevel": {
                    "type": "string"
                  },
                  "clinpgxlevel": {
                    "type": [
                      "null",
                      "string"
                    ]
                  },
                  "pgxtesting": {
                    "type": [
                      "null",
                      "string"
                    ]
                  },
                  "citations": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "items": {
