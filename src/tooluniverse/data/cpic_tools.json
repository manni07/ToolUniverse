                            "type": "string"
                          },
                          "HLA-B": {
                            "type": "string"
                          }
                        }
                      },
                      "drugrecommendation": {
                        "type": "string"
                      },
                      "classification": {
                        "type": "string"
                      },
                      "phenotypes": {
