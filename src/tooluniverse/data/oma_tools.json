[
  {
    "name": "OMA_get_protein",
    "description": "Get protein information from the OMA (Orthologous MAtrix) Browser by UniProt accession or OMA ID. OMA is a comprehensive orthology database covering 2,600+ complete genomes. Returns protein details including species, genomic location, OMA group membership, and Hierarchical Orthologous Group (HOG) assignment. Example: P04637 returns human TP53 with OMA ID HUMAN31534, HOG:E0739094.3a.3b.3b, and genomic locus on chromosome 17.",
    "parameter": {
      "type": "object",
      "properties": {
        "protein_id": {
          "type": "string",
          "description": "UniProt accession (e.g., 'P04637' for human p53) or OMA ID (e.g., 'HUMAN31534'). UniProt accessions are recommended for cross-database compatibility."
        }
      },
      "required": [
        "protein_id"
      ]
    },
    "fields": {
      "endpoint": "protein"
    },
    "type": "OMATool",
    "test_examples": [
      {
        "protein_id": "P04637"
      },
      {
        "protein_id": "P00533"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "entry_nr": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "oma_id": {
                  "type": "string"
                },
                "canonical_id": {
                  "type": "string"
                },
                "sequence_length": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "species_code": {
                  "type": "string"
                },
                "species_name": {
                  "type": "string"
                },
                "taxon_id": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "oma_group": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "oma_hog_id": {
                  "type": "string"
                },
                "chromosome": {
                  "type": "string"
                },
                "locus_start": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "locus_end": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "locus_strand": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "is_main_isoform": {
                  "type": "boolean"
                },
                "roothog_id": {
                  "type": [
                    "integer",
                    "number"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  {
    "name": "OMA_get_orthologs",
    "description": "Get pairwise orthologs for a protein from the OMA (Orthologous MAtrix) Browser. Returns orthologous proteins across species with relationship type (1:1, 1:many, many:1, many:many), evolutionary distance, and alignment score. OMA orthologs are inferred using a rigorous algorithm that provides high-confidence predictions. Example: P04637 (human p53) returns orthologs in 200+ species including Mus musculus, Danio rerio, and Drosophila melanogaster.",
    "parameter": {
      "type": "object",
      "properties": {
        "protein_id": {
          "type": "string",
          "description": "UniProt accession (e.g., 'P04637' for human p53) or OMA ID."
        },
        "rel_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Filter by orthology relationship type. Options: '1:1' (one-to-one), '1:n' (one-to-many), 'n:1' (many-to-one), 'n:m' (many-to-many). Leave empty for all types."
        },
        "per_page": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of orthologs to return (default: 20, max: 100)."
        }
      },
      "required": [
        "protein_id"
      ]
    },
    "fields": {
      "endpoint": "orthologs"
    },
    "type": "OMATool",
    "test_examples": [
      {
        "protein_id": "P04637",
        "per_page": 10
      },
      {
        "protein_id": "P00533",
        "rel_type": "1:1",
        "per_page": 10
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "oma_id": {
                    "type": "string"
                  },
                  "canonical_id": {
                    "type": "string"
                  },
                  "species_name": {
                    "type": "string"
                  },
                  "species_code": {
                    "type": "string"
                  },
                  "taxon_id": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "rel_type": {
                    "type": "string"
                  },
                  "distance": {
                    "type": "number"
                  },
                  "score": {
                    "type": "number"
                  },
                  "sequence_length": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "chromosome": {
                    "type": "string"
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  {
    "name": "OMA_get_hog",
    "description": "Get Hierarchical Orthologous Group (HOG) information from OMA. HOGs represent groups of genes that descended from a single ancestral gene within a given taxonomic range. HOGs capture the full evolutionary history of gene families including gene duplications. Example: HOG:E0739094 returns the p53 HOG at the Euteleostomi level with description 'cellular tumor antigen p53', completeness score 0.65, and child HOGs for fish, mammals, etc.",
    "parameter": {
      "type": "object",
      "properties": {
        "hog_id": {
          "type": "string",
          "description": "Hierarchical Orthologous Group ID. Examples: 'HOG:E0739094' (p53 family), 'HOG:E0817124' (insulin family). Use OMA_get_protein to find the HOG ID for a specific protein."
        }
      },
      "required": [
        "hog_id"
      ]
    },
    "fields": {
      "endpoint": "hog"
    },
    "type": "OMATool",
    "test_examples": [
      {
        "hog_id": "HOG:E0739094"
      },
      {
        "hog_id": "HOG:E0817124"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hog_id": {
                    "type": "string"
                  },
                  "level": {
                    "type": "string"
                  },
                  "roothog_id": {
                    "type": [
                      "integer",
                      "number"
                    ]
                  },
                  "completeness_score": {
                    "type": "number"
                  },
                  "description": {
                    "type": "string"
                  },
                  "parent_hogs": {
                    "type": "array"
                  },
                  "children_hogs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "hog_id": {
                          "type": "string"
                        },
                        "alternative_levels": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "alternative_levels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  {
    "name": "OMA_get_group",
    "description": "Get OMA Group details including member proteins. OMA Groups contain sets of strict 1:1 orthologs across all genomes, ensuring each species contributes at most one gene. This is the most stringent orthology definition in OMA. Example: group 1388790 returns the p53 OMA Group with fingerprint 'HKKGEPC', description 'cellular tumor antigen p53', and members from fish, mammals, and other vertebrates.",
    "parameter": {
      "type": "object",
      "properties": {
        "group_id": {
          "type": "string",
          "description": "OMA Group number (numeric ID). Examples: '1388790' (p53 group), '839588' (EGFR group). Use OMA_get_protein to find the group ID for a specific protein."
        }
      },
      "required": [
        "group_id"
      ]
    },
    "fields": {
      "endpoint": "group"
    },
    "type": "OMATool",
    "test_examples": [
      {
        "group_id": "1388790"
      },
      {
        "group_id": "839588"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status"
          ],
          "properties": {
            "status": {
              "const": "success"
            },
            "data": {
              "type": "object",
              "properties": {
                "group_nr": {
                  "type": [
                    "integer",
                    "number"
                  ]
                },
                "fingerprint": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "members": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "oma_id": {
                        "type": "string"
                      },
                      "canonical_id": {
                        "type": "string"
                      },
                      "species_name": {
                        "type": "string"
                      },
                      "species_code": {
                        "type": "string"
                      },
                      "taxon_id": {
                        "type": [
                          "integer",
                          "number"
                        ]
                      },
                      "sequence_length": {
                        "type": [
                          "integer",
                          "number"
                        ]
                      },
                      "chromosome": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "error"
          ],
          "properties": {
            "status": {
              "const": "error"
            },
            "error": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
]
