  {
    "type": "GetSPLBySetIDTool",
    "name": "DailyMed_get_spl_media",
    "description": "Get the structured list of drug-label images (pill photos, packaging/carton images, figures) for a DailyMed SPL Set ID. Returns each media item's MIME type, file name, and a direct image URL. Useful for pill identification and label review. No API key required. Example: setid '43c94480-78d1-4a23-91d4-1d49fea72cb7' (Ibuprofen Capsule, Aurohealth) returns media including 'ibuprofen-fig1.jpg' (image/jpeg) with its image.cfm URL.",
    "parameter": {
      "type": "object",
      "properties": {
        "setid": {
          "type": "string",
          "format": "uuid",
          "description": "DailyMed SPL Set ID UUID. Example: '43c94480-78d1-4a23-91d4-1d49fea72cb7'."
        }
      },
      "required": [
        "setid"
      ]
    },
    "fields": {
      "resource": "media"
    },
    "test_examples": [
      {
        "setid": "43c94480-78d1-4a23-91d4-1d49fea72cb7"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "data": {
              "type": "object",
              "properties": {
                "setid": {
                  "type": "string"
                },
                "title": {
                  "type": ["string", "null"]
                },
                "spl_version": {
                  "type": ["integer", "null"]
                },
                "media": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "mime_type": {
                        "type": "string",
                        "description": "Image MIME type, e.g., image/jpeg"
                      },
                      "name": {
                        "type": "string",
                        "description": "Media file name"
                      },
                      "url": {
                        "type": "string",
                        "description": "Direct image URL"
                      }
                    }
                  }
                }
              },
              "required": ["setid", "media"]
            },
            "metadata": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "type": "GetSPLBySetIDTool",
    "name": "DailyMed_get_spl_history",
    "description": "Get the full version history of a DailyMed SPL Set ID: every published SPL version with its version number and publication date. Useful for tracking label revisions over time. No API key required. Example: setid '43c94480-78d1-4a23-91d4-1d49fea72cb7' returns history including spl_version 2 (published 'Jun 09, 2026') and spl_version 1 (published 'Jul 22, 2022').",
    "parameter": {
      "type": "object",
      "properties": {
        "setid": {
          "type": "string",
          "format": "uuid",
          "description": "DailyMed SPL Set ID UUID. Example: '43c94480-78d1-4a23-91d4-1d49fea72cb7'."
        }
      },
      "required": [
        "setid"
      ]
    },
    "fields": {
      "resource": "history"
    },
    "test_examples": [
      {
        "setid": "43c94480-78d1-4a23-91d4-1d49fea72cb7"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string"
            },
            "data": {
              "type": "object",
              "properties": {
                "setid": {
                  "type": "string"
                },
                "title": {
                  "type": ["string", "null"]
                },
                "history": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "spl_version": {
                        "type": "integer",
                        "description": "SPL version number"
                      },
                      "published_date": {
                        "type": "string",
                        "description": "Publication date, e.g., 'Jul 22, 2022'"
                      }
                    }
                  }
                }
              },
              "required": ["setid", "history"]
            },
            "metadata": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": ["error"]
        }
      ]
    }
  }
]
