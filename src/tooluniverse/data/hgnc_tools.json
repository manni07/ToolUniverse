  {
    "name": "HGNC_search_genes",
    "description": "Search for human genes in HGNC by symbol, name, or alias. Supports wildcards (e.g., 'BRCA*' finds BRCA1, BRCA2). Searches across approved symbols and names. Returns a list of matching genes with basic info. Example: 'kinase' searches gene names containing kinase.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query - gene symbol, partial name, or keyword. Supports wildcards (*). Examples: 'BRCA*', 'tumor protein', 'insulin receptor'."
        },
        "search_field": {
          "type": [
            "string",
            "null"
          ],
          "description": "Field to search in. Options: 'symbol', 'name', 'alias_symbol', 'prev_symbol', 'entrez_id', 'ensembl_gene_id', 'uniprot_ids', 'location'. Default searches across symbol and name."
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "endpoint": "search",
      "search_field": null
    },
    "type": "HGNCTool",
    "test_examples": [
      {
        "query": "BRCA*"
      },
      {
        "query": "tumor protein",
        "search_field": "name"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hgnc_id": {
                    "type": "string"
                  },
                  "symbol": {
                    "type": "string"
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "status": {
                    "type": "string"
                  },
                  "location": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "total_results": {
                  "type": "integer"
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "HGNC_search_by_location",
    "description": "Search HGNC for genes at a specific chromosomal location. Returns all genes mapped to that cytogenetic band. Useful for identifying genes in a chromosomal region of interest. Example: '17p13.1' returns genes including TP53.",
    "parameter": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "description": "Cytogenetic band location. Examples: '17p13.1' (TP53 region), '17q21.31' (BRCA1 region), '7p11.2' (EGFR region), '13q14.2' (RB1 region)."
        }
      },
      "required": [
        "location"
      ]
    },
    "fields": {
      "endpoint": "search",
      "search_field": "location"
    },
    "type": "HGNCTool",
    "test_examples": [
      {
        "location": "17p13.1"
      },
      {
        "location": "17q21.31"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hgnc_id": {
                    "type": "string"
                  },
                  "symbol": {
                    "type": "string"
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "status": {
                    "type": "string"
                  },
                  "location": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "locus_type": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "total_results": {
                  "type": "integer"
                },
                "query_location": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
