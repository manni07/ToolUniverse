# API Keys for ToolUniverse
# AUTO-GENERATED by scripts/gen_api_key_catalog.py - DO NOT EDIT BY HAND.
# Edit the api_key_info block in the relevant tool config under
# src/tooluniverse/data/, then re-run the generator.
# Copy to .env or ~/.tooluniverse/.env and fill in the keys you need.

# === Genomics & Variants ===

# CELLXGENE_CENSUS_PACKAGE_INSTALLED (required) — Synthetic gate. Set to '1' after `pip install cellxgene-census`; CELLxGENE tools require the Python package, not a network key. (https://chanzuckerberg.github.io/cellxgene-census/)
# Without: All 7 CELLxGENE tools skip in the test harness and return a clear 'package not installed' error at runtime.
CELLXGENE_CENSUS_PACKAGE_INSTALLED=

# DISGENET_API_KEY (required) — Pull curated gene–disease association scores and supporting evidence. (https://www.disgenet.org/)
# Without: Limited public data works without it; the key unlocks full access.
DISGENET_API_KEY=

# OMIM_API_KEY (required) — Look up Mendelian disease–gene relationships and clinical variant records for interpretation. (https://omim.org/api)
# Without: OMIM tools return no data without it. Free for academic use.
OMIM_API_KEY=

# PHARMVAR_API_KEY (required) — Resolve pharmacogene star-allele definitions (e.g. CYP2D6, CYP2C19). (https://www.pharmvar.org/)
# Without: PharmVar tools are blocked without it.
PHARMVAR_API_KEY=

# === Drugs & Chemistry ===

# BRENDA_EMAIL (required) — BRENDA account email — retrieves enzyme kinetics, substrates, and parameters. (https://www.brenda-enzymes.org/register.php)
# Without: BRENDA tools are blocked without an account (paired with the password).
BRENDA_EMAIL=

# BRENDA_PASSWORD (required) — BRENDA account password — authenticates the enzyme-data SOAP API. (https://www.brenda-enzymes.org/register.php)
# Without: Required together with the BRENDA email.
BRENDA_PASSWORD=

# CLUE_API_KEY (required) — Query Connectivity Map drug–gene perturbation signatures for repurposing. (https://clue.io)
# Without: CLUE tools are blocked without it. The key is free.
CLUE_API_KEY=

# MCULE_API_KEY (optional) — Check purchasability and pricing of chemical compounds. (https://mcule.com/api/)
# Without: Compound search works without it; the key unlocks ordering and availability.
MCULE_API_KEY=

# ONCOKB_API_TOKEN (optional) — Annotate cancer variants with oncogenicity and matched therapy implications. (https://www.oncokb.org/apiAccess)
# Without: Runs in demo mode (BRAF, TP53, ROS1 only) without a token.
ONCOKB_API_TOKEN=

# === Proteins & Structure ===

# ADDGENE_API_KEY (required) — Look up plasmids and deposited constructs from the Addgene repository. (https://www.addgene.org/contact/)
# Without: Addgene tools are blocked without it.
ADDGENE_API_KEY=

# BIOGRID_ACCESS_KEY (required) — Retrieve protein–protein and genetic interaction networks. (https://webservice.thebiogrid.org/)
# Without: BioGRID tools are blocked without it. The key is free.
BIOGRID_ACCESS_KEY=

# ESM_API_KEY (required) — Run EvolutionaryScale ESM protein language models (embeddings, structure prediction). (https://forge.evolutionaryscale.ai/)
# Without: ESM Forge tools are blocked without it.
ESM_API_KEY=

# HF_TOKEN (required) — Download Hugging Face models and datasets used by structure/sequence tools. (https://huggingface.co/settings/tokens)
# Without: Public models work without it; needed for gated or private repos.
HF_TOKEN=

# === Literature & Patents ===

# NCBI_API_KEY (optional) — Search PubMed and fetch citation metrics (iCite) and PubTator annotations. (https://www.ncbi.nlm.nih.gov/account/)
# Without: Works at 3 requests/sec without it; the key raises the limit to 10/sec.
NCBI_API_KEY=

# SEMANTIC_SCHOLAR_API_KEY (optional) — Search papers and traverse citation graphs via Semantic Scholar. (https://www.semanticscholar.org/product/api)
# Without: Works at ~1 request/sec without it; the key raises rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# USPTO_API_KEY (required) — Search US patents and patent-application full text. (https://developer.uspto.gov/)
# Without: USPTO patent tools are blocked without it.
USPTO_API_KEY=

# === Clinical & Safety ===

# CENSUS_API_KEY (required) — Pull population, demographic, and economic data from the US Census Bureau (decennial + ACS). (https://api.census.gov/data/key_signup.html)
# Without: Census endpoints return an HTML rate-limit page that breaks the tool's JSON parser. Free to register.
CENSUS_API_KEY=

# FDA_API_KEY (optional) — Query FDA drug labels, adverse-event reports (FAERS), and recalls. (https://open.fda.gov/apis/authentication/)
# Without: Works at 240 requests/min without it; the key raises it to 120,000/day.
FDA_API_KEY=

# FDC_API_KEY (optional) — Look up food and nutrient composition from USDA FoodData Central. (https://fdc.nal.usda.gov/api-guide.html)
# Without: Falls back to a shared, rate-limited DEMO_KEY without it.
FDC_API_KEY=

# ICD_CLIENT_ID (optional) — WHO ICD-11 API client ID (OAuth) for disease classification lookups. (https://icd.who.int/icdapi)
# Without: ICD-11 tools are blocked without it (paired with the client secret).
ICD_CLIENT_ID=

# ICD_CLIENT_SECRET (optional) — WHO ICD-11 API client secret (OAuth), used with the client ID. (https://icd.who.int/icdapi)
# Without: Required together with ICD_CLIENT_ID.
ICD_CLIENT_SECRET=

# UMLS_API_KEY (optional) — Authenticate to UMLS for concept, SNOMED CT, and LOINC lookups. (https://uts.nlm.nih.gov/uts/signup-login)
# Without: UMLS/SNOMED/LOINC tools are blocked without it (free UMLS license).
UMLS_API_KEY=

# === Models & Infrastructure ===

# AZURE_OPENAI_API_KEY (optional) — Use Azure-hosted OpenAI models for embeddings (enterprise alternative to OpenAI). (https://portal.azure.com/)
# Without: Optional alternative to OpenAI — leave blank if you don't use Azure.
AZURE_OPENAI_API_KEY=

# BOLTZ_MCP_SERVER_HOST (required) — URL of a self-hosted Boltz structure-prediction MCP server. (https://github.com/jwohlwend/boltz)
# Without: Leave blank unless you run your own Boltz server.
BOLTZ_MCP_SERVER_HOST=

# ESM_MCP_SERVER_HOST (required) — URL of a self-hosted ESM MCP server. (https://forge.evolutionaryscale.ai/)
# Without: Leave blank unless you run your own ESM server.
ESM_MCP_SERVER_HOST=

# EXPERT_FEEDBACK_MCP_SERVER_URL (required) — URL of a self-hosted expert-feedback MCP service. (https://github.com/mims-harvard/ToolUniverse)
# Without: Leave blank unless you run this service.
EXPERT_FEEDBACK_MCP_SERVER_URL=

# GEMINI_API_KEY (optional) — Use Google Gemini models for LLM-backed (agentic) tools. (https://aistudio.google.com/apikey)
# Without: Only needed if you select Gemini as the agentic LLM provider.
GEMINI_API_KEY=

# NVIDIA_API_KEY (required) — Call NVIDIA NIM model endpoints (hosted inference for bio/chem models). (https://build.nvidia.com/)
# Without: NIM tools are blocked without it.
NVIDIA_API_KEY=

# OPENAI_API_KEY (optional) — Generate text embeddings for the semantic tool finder. (https://platform.openai.com/api-keys)
# Without: The tool finder falls back to local embeddings without it.
OPENAI_API_KEY=

# OPENROUTER_API_KEY (optional) — Use OpenRouter-hosted models for LLM-backed (agentic) tools. (https://openrouter.ai/keys)
# Without: Only needed if you select OpenRouter as the agentic LLM provider.
OPENROUTER_API_KEY=

# TXAGENT_MCP_SERVER_HOST (required) — URL of a self-hosted TxAgent MCP server. (https://github.com/mims-harvard/TxAgent)
# Without: Leave blank unless you run your own TxAgent.
TXAGENT_MCP_SERVER_HOST=

# USPTO_MCP_SERVER_HOST (required) — URL of a self-hosted USPTO MCP server. (https://developer.uspto.gov/)
# Without: Leave blank unless you run your own USPTO server.
USPTO_MCP_SERVER_HOST=
